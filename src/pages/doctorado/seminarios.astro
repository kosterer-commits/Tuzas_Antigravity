---
import Layout from "../../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL || "/";
---

<Layout title="Seminarios - Doctorado en Ingeniería Mecánica">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            position: relative;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
        }

        .doctorado-container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            padding: 150px 20px 60px 20px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .doctorado-title {
            text-align: center;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 20px;
            text-shadow: 0 0 20px rgba(27, 57, 106, 0.6);
        }

        .doctorado-subtitle {
            text-align: center;
            font-size: 1.5rem;
            color: #c5a059;
            font-weight: 600;
            margin-bottom: 80px;
            letter-spacing: 2px;
        }

        /* Glassmorphism Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.125);
            border-radius: 24px;
            padding: clamp(30px, 4vw, 50px);
            margin-bottom: 60px;
            width: 100%;
            max-width: 1100px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            border-top: 10px solid #1b396a;
        }

        .glass-card.gold-accent {
            border-top-color: #c5a059;
        }

        .seminar-img {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
            display: block;
            margin: 0 auto;
            transition: transform 0.4s ease;
        }

        .seminar-img:hover {
            transform: scale(1.02);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.5);
        }

        @media (max-width: 992px) {
            .doctorado-container {
                padding: 120px 20px 40px;
            }
        }

        @media (max-width: 768px) {
            .doctorado-title {
                font-size: 2.2rem;
                line-height: 1.2;
                margin-bottom: 15px;
            }
            .doctorado-subtitle {
                font-size: 1.2rem;
                margin-bottom: 50px;
            }
            .glass-card {
                padding: 25px 20px;
                margin-bottom: 40px;
            }
        }
    </style>

    <div class="doctorado-container">
        <h1 class="doctorado-title">Seminario de Investigación</h1>
        <h3 class="doctorado-subtitle">
            Doctorado en Ciencias en Ingeniería Mecánica
        </h3>

        <div class="glass-card">
            <img
                src={`${BASE}images/programa seminario de posgrado.png`}
                class="seminar-img"
                alt="Programa Seminario de Posgrado"
            />
        </div>

        <div class="glass-card gold-accent">
            <img
                src={`${BASE}images/collage seminario de posgrado.png`}
                class="seminar-img"
                alt="Collage Fotográfico Seminario de Posgrado"
            />
        </div>
    </div>
</Layout>
