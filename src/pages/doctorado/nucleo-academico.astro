---
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs/promises";
import path from "node:path";

const BASE = import.meta.env.BASE_URL || "/";

// Leer el JSON generado con la información de profesores de doctorado
const jsonPath = path.resolve("public/data/profesores-doctorado.json");
let profesoresContent = [];
try {
    const fileData = await fs.readFile(jsonPath, "utf-8");
    profesoresContent = JSON.parse(fileData);
} catch (error) {
    console.error("Error reading profesores-doctorado.json", error);
}

// Lista manual con el resumen de la tabla, cruzada con el slug del JSON
