---

<Layout title="Núcleo Académico - Doctorado en Ingeniería Mecánica">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
            /* Allow scrolling on body even when modal is open if we want, but better to lock it via JS */
        }

        .no-scroll {
            overflow: hidden;
        }

        .hero {
            text-align: center;
            padding: 160px 20px 60px;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(197, 160, 89, 0.15);
            border: 1px solid rgba(197, 160, 89, 0.4);
            color: #c5a059;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 8px 20px;
            border-radius: 50px;
            margin-bottom: 24px;
            backdrop-filter: blur(8px);
        }

        .hero-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 3px;
            line-height: 1.1;
            margin: 0 auto 16px;
            max-width: 900px;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        .hero-title span {
            color: #c5a059;
        }

        .hero-divider {
            width: 80px;
            height: 4px;
            background: linear-gradient(
                to right,
                transparent,
                #c5a059,
                transparent
            );
            margin: 0 auto 20px;
            border-radius: 4px;
        }

        .hero-sub {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1.1rem;
            margin: 0;
        }

        .page-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px 80px;
        }

        .table-glass {
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.125);
            border-radius: 20px;
            padding: clamp(20px, 4vw, 40px);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            border-top: 10px solid #1b396a;
            overflow-x: auto;
        }

        .custom-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 8px;
            min-width: 700px;
        }

        .custom-table thead th {
            background-color: #1b396a;
            color: white;
            padding: 16px 20px;
            text-transform: uppercase;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 1px;
            text-align: left;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .custom-table thead th:first-child {
            border-radius: 12px 0 0 12px;
        }

        .custom-table thead th:last-child {
            border-radius: 0 12px 12px 0;
            border-right: none;
            text-align: center;
        }

        .custom-table tbody tr {
            transition: all 0.3s ease;
            background: rgba(27, 57, 106, 0.03);
        }

        .custom-table tbody tr:hover {
            transform: translateY(-2px);
            background: rgba(27, 57, 106, 0.06);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .custom-table td {
            padding: 18px 20px;
            vertical-align: middle;
            color: #334155;
            font-size: 1.05rem;
            border-top: 1px solid rgba(0, 0, 0, 0.02);
            border-bottom: 1px solid rgba(0, 0, 0, 0.02);
        }

        .custom-table td:first-child {
            border-left: 1px solid rgba(0, 0, 0, 0.02);
            border-radius: 12px 0 0 12px;
        }

        .custom-table td:last-child {
            border-right: 1px solid rgba(0, 0, 0, 0.02);
            border-radius: 0 12px 12px 0;
            text-align: center;
        }

        .lgac-badge {
            background: #c5a059;
            color: #030712;
            padding: 6px 14px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 0.8rem;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 10px rgba(197, 160, 89, 0.2);
        }

        .professor-name {
            font-weight: 700;
            color: #1b396a;
            font-size: 1.1rem;
        }

        .cv-button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #1b396a;
            color: white !important;
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        .cv-button:hover {
            background: #c5a059;
            transform: translateY(-3px);
            box-shadow: 0 6px 16px rgba(197, 160, 89, 0.3);
        }

        /* -----------------------
           Estilos del Modal
           ----------------------- */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(10, 14, 39, 0.85); /* Tema oscuro */
            backdrop-filter: blur(8px);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
            padding: 20px;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            background: #ffffff;
            width: 100%;
            max-width: 900px;
            max-height: 90vh;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 25px 80px rgba(0, 0, 0, 0.5);
            transform: scale(0.95) translateY(20px);
            transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
            position: relative;
            display: flex;
            flex-direction: column;
            border-top: 8px solid #c5a059;
        }

        .modal-overlay.active .modal-content {
            transform: scale(1) translateY(0);
        }

        .modal-close {
            position: absolute;
            top: 20px;
            right: 20px;
            background: rgba(255, 255, 255, 0.2);
            border: none;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #1b396a;
            cursor: pointer;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .modal-close:hover {
            background: #ffebee;
            color: #d32f2f;
            transform: rotate(90deg);
        }

        /* Header del Modal */
        .modal-header {
            background: linear-gradient(
                135deg,
                rgba(27, 57, 106, 0.05),
                rgba(27, 57, 106, 0.15)
            );
            padding: 40px;
            display: flex;
            gap: 30px;
            align-items: center;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .modal-avatar {
            width: 140px;
            height: 140px;
            border-radius: 20px;
            object-fit: cover;
            box-shadow: 0 10px 25px rgba(27, 57, 106, 0.2);
            border: 4px solid #fff;
            background: #fff;
        }

        .modal-header-info {
            flex: 1;
        }

        .modal-prof-name {
            font-size: 2rem;
            color: #1b396a;
            margin: 0 0 5px 0;
            font-weight: 800;
            line-height: 1.2;
        }

        .modal-prof-title {
            color: #c5a059;
            font-size: 1.1rem;
            font-weight: 700;
            margin: 0 0 15px 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .modal-contact {
            display: flex;
            flex-direction: column;
            gap: 8px;
            color: #475569;
            font-size: 0.95rem;
        }

        .modal-contact div {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-contact i {
            color: #1b396a;
            width: 16px;
            text-align: center;
        }

        /* Cuerpo del modál */
        .modal-body {
            padding: 0;
            overflow-y: auto;
            flex: 1;
            /* Scroll styling */
            scrollbar-width: thin;
            scrollbar-color: #c5a059 #f1f5f9;
        }

        .modal-body::-webkit-scrollbar {
            width: 8px;
        }
        .modal-body::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        .modal-body::-webkit-scrollbar-thumb {
            background-color: #c5a059;
            border-radius: 10px;
        }

        /* Pestañas */
        .modal-tabs {
            display: flex;
            background: #f8fafc;
            border-bottom: 2px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 5;
            overflow-x: auto;
        }

        .modal-tab-btn {
            padding: 16px 24px;
            background: none;
            border: none;
            color: #64748b;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            border-bottom: 3px solid transparent;
            font-family: inherit;
            white-space: nowrap;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .modal-tab-btn:hover {
            color: #1b396a;
            background: rgba(27, 57, 106, 0.05);
        }

        .modal-tab-btn.active {
            color: #1b396a;
            border-bottom-color: #c5a059;
            background: #fff;
        }

        .modal-tab-btn i {
            font-size: 1.1em;
        }

        /* Contenidos de las Pestañas */
        .modal-tab-content {
            padding: 40px;
            display: none;
            animation: fadeIn 0.4s ease;
            color: #334155;
            line-height: 1.8;
            font-size: 1.05rem;
        }

        .modal-tab-content.active {
            display: block;
        }

        .modal-tab-content h3 {
            color: #1b396a;
            margin-top: 0;
            margin-bottom: 20px;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 10px;
            border-bottom: 2px solid rgba(197, 160, 89, 0.2);
        }

        /* Estilización interna del HTML exportado */
        .modal-tab-content ul {
            padding-left: 20px;
            margin-bottom: 25px;
        }

        .modal-tab-content li {
            margin-bottom: 12px;
        }

        .modal-tab-content li strong {
            color: #1b396a;
        }

        .modal-tab-content p {
            margin-bottom: 20px;
        }

        /* Etiquetas para LGACs */
        .lgac-tag-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }

        .lgac-tag {
            background: rgba(27, 57, 106, 0.1);
            color: #1b396a;
            padding: 8px 16px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
            border: 1px solid rgba(27, 57, 106, 0.2);
        }

        /* Animaciones */
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Animación de carga */
        .loader {
            display: none;
            width: 48px;
            height: 48px;
            border: 5px solid #e2e8f0;
            border-bottom-color: #c5a059;
            border-radius: 50%;
            display: inline-block;
            box-sizing: border-box;
            animation: rotation 1s linear infinite;
            margin: 40px auto;
        }

        @keyframes rotation {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }

        /* Responsivo */
        @media (max-width: 900px) {
            .hero {
                padding-top: 130px;
            }
            .hero-title {
                font-size: 2.5rem;
            }
        }

        @media (max-width: 768px) {
            .custom-table thead {
                display: none;
            }
            .custom-table,
            .custom-table tbody,
            .custom-table tr,
            .custom-table td {
                display: block;
                width: 100%;
                min-width: auto;
            }
            .custom-table tr {
                margin-bottom: 15px;
                border-radius: 16px;
                border: 1px solid rgba(0, 0, 0, 0.1);
                background: white;
            }
            .custom-table td {
                padding: 15px;
                text-align: left !important;
                border: none !important;
                position: relative;
                padding-left: 40%;
                border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important;
            }
            .custom-table td:last-child {
                border-bottom: none !important;
            }
            .custom-table td:before {
                content: attr(data-label);
                position: absolute;
                left: 15px;
                top: 16px;
                font-size: 0.8rem;
                font-weight: 800;
                color: #c5a059;
                text-transform: uppercase;
            }

            /* Modal Responsive */
            .modal-content {
                max-height: 95vh;
                height: 95vh;
                border-radius: 12px;
            }
            .modal-header {
                flex-direction: column;
                text-align: center;
                padding: 30px 20px;
            }
            .modal-avatar {
                width: 100px;
                height: 100px;
                margin: 0 auto;
            }
            .modal-close {
                top: 10px;
                right: 10px;
                background: rgba(0, 0, 0, 0.05);
            }
            .modal-prof-name {
                font-size: 1.5rem;
            }
            .modal-contact div {
                justify-content: center;
            }
            .modal-tab-content {
                padding: 25px 20px;
            }
            .modal-tab-btn {
                padding: 12px 16px;
                font-size: 0.85rem;
            }

            .lgac-tag-container {
                justify-content: center;
            }
        }
    </style>

    <div class="hero">
        <div class="hero-badge">Investigadores</div>
        <h1 class="hero-title">Núcleo <span>Académico</span></h1>
        <div class="hero-divider"></div>
        <p class="hero-sub">Doctorado en Ciencias en Ingeniería Mecánica</p>
    </div>

    <div class="page-wrap">
        <div class="table-glass">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th style="width: 15%;">LGAC</th>
                        <th style="width: 45%;">Nombre del Investigador</th>
                        <th style="width: 20%;">Distinción</th>
                        <th style="width: 20%;">Perfil</th>
                    </tr>
                </thead>
                <tbody>
                    {
                        profesores.map((prof) => (
                            <tr key={prof.slug}>
                                <td data-label="LGAC">
                                    <span class="lgac-badge">{prof.lgac}</span>
                                </td>
                                <td data-label="Nombre">
                                    <span class="professor-name">
                                        {prof.nombre}
                                    </span>
                                </td>
                                <td data-label="Distinción">{prof.dist}</td>
                                <td data-label="Perfil">
                                    <button
                                        class="cv-button"
                                        data-slug={prof.slug}
                                    >
                                        <i class="fa-solid fa-address-card" />{" "}
                                        Ver Perfil
                                    </button>
                                </td>
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- MODAL DINÁMICO -->
    <div class="modal-overlay" id="profModalOverlay">
        <div class="modal-content" id="profModalContent">
            <button class="modal-close" id="closeModalBtn" title="Cerrar modal">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <!-- Contenedor del estado de carga -->
            <div
                id="modalLoader"
                style="display: flex; justify-content: center; align-items: center; height: 100%; width: 100%;"
            >
                <span class="loader" style="display: block;"></span>
            </div>

            <!-- Contenido que será inyectado -->
            <div
                id="modalDataContainer"
                style="display: none; display: flex; flex-direction: column; height: 100%;"
            >
                <div class="modal-header">
                    <img
                        id="mAvatar"
                        src=""
                        alt="Avatar"
                        class="modal-avatar"
                    />
                    <div class="modal-header-info">
                        <h2 id="mName" class="modal-prof-name">Nombre</h2>
                        <h4 id="mTitle" class="modal-prof-title">Título</h4>
                        <div id="mContact" class="modal-contact">
                            <!-- Inyectado dinámicamente -->
                        </div>
                    </div>
                </div>

                <div class="modal-tabs">
                    <button
                        class="modal-tab-btn active"
                        data-target="mTabFormacion"
                    >
                        <i class="fa-solid fa-graduation-cap"></i> Formación
                    </button>
                    <button
                        class="modal-tab-btn"
                        data-target="mTabProductividad"
                    >
                        <i class="fa-solid fa-book-open"></i> Productividad
                    </button>
                    <button class="modal-tab-btn" data-target="mTabProyectos">
                        <i class="fa-solid fa-flask"></i> Proyectos
                    </button>
                    <button
                        class="modal-tab-btn"
                        data-target="mTabDistinciones"
                    >
                        <i class="fa-solid fa-medal"></i> Distinciones
                    </button>
                </div>

                <div class="modal-body">
                    <!-- Formación y Áreas -->
                    <div class="modal-tab-content active" id="mTabFormacion">
                        <h3>
                            <i
                                class="fa-solid fa-microscope"
                                style="color:#c5a059;"></i> Líneas de Generación y
                            Aplicación del Conocimiento
                        </h3>
                        <div
                            id="mLGACs"
                            class="lgac-tag-container"
                            style="margin-bottom: 30px;"
                        >
                            <!-- Inyectado. -->
                        </div>

                        <h3>
                            <i
                                class="fa-solid fa-graduation-cap"
                                style="color:#c5a059;"></i> Grados Académicos
                        </h3>
                        <div id="mDegrees">
                            <!-- Inyectado. -->
                        </div>
                    </div>

                    <!-- Productividad -->
                    <div class="modal-tab-content" id="mTabProductividad">
                        <h3>
                            <i
                                class="fa-solid fa-book-open"
                                style="color:#c5a059;"></i> Productividad Académica
                            Reciente
                        </h3>
                        <div id="mProductivityBody"></div>
                    </div>

                    <!-- Proyectos -->
                    <div class="modal-tab-content" id="mTabProyectos">
                        <h3>
                            <i class="fa-solid fa-flask" style="color:#c5a059;"
                            ></i> Proyectos / Patentes
                        </h3>
                        <div id="mProjectsBody"></div>
                    </div>

                    <!-- Distinciones -->
                    <div class="modal-tab-content" id="mTabDistinciones">
                        <h3>
                            <i class="fa-solid fa-medal" style="color:#c5a059;"
                            ></i> Reconocimientos
                        </h3>
                        <div id="mDistinctionsBody"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- PASAR DATOS A CLIENTE VÍA SCRIPT TAG -->
    <script
        id="profDataScript"
        type="application/json"
        set:html={JSON.stringify(profesoresContent)}
    />

    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const BASE = import.meta.env.BASE_URL || "/"; // Use base URL

            // 1) Leer la data incrustada
            const scriptTag = document.getElementById("profDataScript");
            let db = [];
            if (scriptTag) {
                try {
                    db = JSON.parse(scriptTag.textContent);
                } catch (e) {
                    console.error("Error parsing JSON DB", e);
                }
            }

            // 2) Elementos del DOM
            const overlay = document.getElementById("profModalOverlay");
            const closeBtn = document.getElementById("closeModalBtn");
            const loader = document.getElementById("modalLoader");
            const dataContainer = document.getElementById("modalDataContainer");

            const mAvatar = document.getElementById("mAvatar");
            const mName = document.getElementById("mName");
            const mTitle = document.getElementById("mTitle");
            const mContact = document.getElementById("mContact");

            const mLGACs = document.getElementById("mLGACs");
            const mDegrees = document.getElementById("mDegrees");

            const mProductivityBody =
                document.getElementById("mProductivityBody");
            const mProjectsBody = document.getElementById("mProjectsBody");
            const mDistinctionsBody =
                document.getElementById("mDistinctionsBody");

            // 3) Funciones del Modal interactivo
            const openModal = (slug) => {
                // Bloquear scroll del body
                document.body.classList.add("no-scroll");

                // Reset states
                dataContainer.style.display = "none";
                loader.style.display = "flex";
                overlay.classList.add("active");

                // Buscar datos
                const profData = db.find((p) => p.slug === slug);

                setTimeout(() => {
                    if (profData) {
                        renderModal(profData);
                        loader.style.display = "none";
                        dataContainer.style.display = "flex";
                    } else {
                        // Fallback
                        alert("Error: No se encontró información del perfil.");
                        closeModal();
                    }
                }, 300); // Pequeña animación artificial (300ms)
            };

            const closeModal = () => {
                overlay.classList.remove("active");
                // Liberar scroll
                document.body.classList.remove("no-scroll");
            };

            const renderModal = (data) => {
                const fotoFinal = data.foto ? data.foto : "default.jpg";

                // Usar BASE para que las imágenes funcionen en Github Pages/Subrutas
                mAvatar.src = `${BASE}images/DEPI/${fotoFinal}`;

                mName.textContent = data.nombreCompleto || "Catedrático";
                mTitle.textContent =
                    data.titulo || "Profesor(a) del Núcleo Académico";

                // Procesar Contacto
                mContact.innerHTML = "";
                if (data.contacto) {
                    const contacts = data.contacto
                        .split("|")
                        .map((s) => s.trim());
                    contacts.forEach((c) => {
                        let icon = '<i class="fa-solid fa-address-book"></i>';
                        if (c.includes("@"))
                            icon = '<i class="fa-solid fa-envelope"></i>';
                        else if (c.match(/\d/))
                            icon = '<i class="fa-solid fa-phone"></i>';

                        mContact.innerHTML += `<div>${icon} <span>${c}</span></div>`;
                    });
                } else {
                    mContact.innerHTML = `<div><i class="fa-solid fa-triangle-exclamation"></i> <span>No hay datos de contacto.</span></div>`;
                }

                // Generar LGACs
                mLGACs.innerHTML = "";
                if (data.areas && Array.isArray(data.areas)) {
                    data.areas.forEach((a) => {
                        mLGACs.innerHTML += `<div class="lgac-tag">${a}</div>`;
                    });
                }

                // Inyectar HTML seguro (viene limpiado desde el scraper)
                mDegrees.innerHTML =
                    data.formacion || "<p>Sin registros detectados.</p>";
                mProductivityBody.innerHTML =
                    data.productividad || "<p>Sin registros detectados.</p>";
                mProjectsBody.innerHTML =
                    data.proyectos || "<p>Sin registros detectados.</p>";
                mDistinctionsBody.innerHTML =
                    data.distinciones || "<p>Sin distinciones detectadas.</p>";

                // Reset a pestaña de formación
                document
                    .querySelectorAll(".modal-tab-btn")
                    .forEach((btn) => btn.classList.remove("active"));
                document
                    .querySelectorAll(".modal-tab-content")
                    .forEach((c) => c.classList.remove("active"));

                const initialTab = document.querySelector(
                    '[data-target="mTabFormacion"]',
                );
                if (initialTab) {
                    initialTab.classList.add("active");
                    document
                        .getElementById("mTabFormacion")
                        .classList.add("active");
                }
            };

            // 4) Listeners
            document.querySelectorAll(".cv-button").forEach((btn) => {
                btn.addEventListener("click", (e) => {
                    const slug = e.currentTarget.getAttribute("data-slug");
                    if (slug) openModal(slug);
                });
            });

            closeBtn.addEventListener("click", closeModal);
            overlay.addEventListener("click", (e) => {
                if (e.target === overlay) closeModal();
            });

            // Pestañas
            const tabBtns = document.querySelectorAll(".modal-tab-btn");
            const tabContents = document.querySelectorAll(".modal-tab-content");

            tabBtns.forEach((btn) => {
                btn.addEventListener("click", () => {
                    // Remover activas
                    tabBtns.forEach((b) => b.classList.remove("active"));
                    tabContents.forEach((c) => c.classList.remove("active"));

                    // Activar seleccionada
                    btn.classList.add("active");
                    const targetId = btn.getAttribute("data-target");
                    document.getElementById(targetId).classList.add("active");
                });
            });

            // Cerrar con Escape
            document.addEventListener("keydown", (e) => {
                if (
                    e.key === "Escape" &&
                    overlay.classList.contains("active")
                ) {
                    closeModal();
                }
            });
        });
    </script>
</Layout>
