---
import Layout from "../../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
---

<Layout title="Doctorado en Ingeniería Mecánica - TecNM">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            position: relative;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
        }

        /* ── HERO ──────────────────────────────────────────────── */
        .hero {
            text-align: center;
            padding: 160px 20px 60px;
            position: relative;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(197, 160, 89, 0.15);
            border: 1px solid rgba(197, 160, 89, 0.4);
            color: #c5a059;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 8px 20px;
            border-radius: 50px;
            margin-bottom: 24px;
            backdrop-filter: blur(8px);
        }

        .hero-title {
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 900;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 3px;
            line-height: 1.1;
            margin: 0 auto 16px;
            max-width: 900px;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }

        .hero-title span {
            color: #c5a059;
        }

        .hero-divider {
            width: 80px;
            height: 4px;
            background: linear-gradient(
                to right,
                transparent,
                #c5a059,
                transparent
            );
            margin: 0 auto 20px;
            border-radius: 4px;
        }

        .hero-sub {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1.1rem;
            letter-spacing: 0.05em;
            margin: 0;
        }

        /* ── CONTAINER ─────────────────────────────────────────── */
        .page-wrap {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 24px 80px;
        }

        /* ── WELCOME BANNER ────────────────────────────────────── */
        .welcome-banner {
            background: linear-gradient(
                135deg,
                rgba(27, 57, 106, 0.85) 0%,
                rgba(10, 20, 50, 0.9) 100%
            );
            backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.25);
            border-radius: 24px;
            padding: 48px 56px;
            margin-bottom: 64px;
            position: relative;
            overflow: hidden;
        }

        .welcome-banner::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(to bottom, #c5a059, #1b396a);
            border-radius: 24px 0 0 24px;
        }

        .welcome-banner::after {
            content: '"';
            position: absolute;
            right: 40px;
            top: -20px;
            font-size: 180px;
            color: rgba(197, 160, 89, 0.07);
            font-family: Georgia, serif;
            line-height: 1;
            pointer-events: none;
        }

        .welcome-label {
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: #c5a059;
            margin-bottom: 12px;
        }

        .welcome-text {
            color: rgba(255, 255, 255, 0.9);
            font-size: 1.15rem;
            line-height: 1.85;
            margin: 0;
        }

        /* ── SECTION TITLE ─────────────────────────────────────── */
        .section-title {
            text-align: center;
            color: #fff;
            font-size: clamp(1.4rem, 2.5vw, 2rem);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0 0 40px;
            position: relative;
        }

        .section-title::after {
            content: "";
            display: block;
            width: 50px;
            height: 3px;
            background: #c5a059;
            margin: 12px auto 0;
            border-radius: 2px;
        }

        /* ── INFO GRID (objetivo + dirigido) ───────────────────── */
        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 64px;
        }

        .glass-card {
            background: rgba(10, 20, 50, 0.82);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.2);
            border-radius: 20px;
            padding: 36px 40px;
            transition: all 0.35s ease;
            position: relative;
            overflow: hidden;
        }

        .glass-card:hover {
            background: rgba(10, 20, 50, 0.92);
            border-color: rgba(197, 160, 89, 0.5);
            transform: translateY(-4px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
        }

        .glass-card .card-icon {
            font-size: 2.2rem;
            margin-bottom: 16px;
        }

        .glass-card h2 {
            font-size: 1.15rem;
            font-weight: 800;
            color: #c5a059;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 0 14px;
        }

        .glass-card p {
            font-size: 1rem;
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.85);
            margin: 0;
            text-align: justify;
        }

        /* ── NAV CARDS GRID (Plan, Admisión, LGAC, Núcleo, Vinc) ─ */
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 64px;
        }

        .nav-card {
            background: rgba(10, 20, 50, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            padding: 36px 28px;
            text-decoration: none;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 14px;
            transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            overflow: hidden;
        }

        .nav-card::before {
            content: "";
            position: absolute;
            inset: 0;
            opacity: 0;
            transition: opacity 0.35s ease;
            border-radius: 20px;
        }

        .nav-card.blue::before {
            background: linear-gradient(
                135deg,
                rgba(27, 57, 106, 0.5),
                rgba(27, 57, 106, 0.2)
            );
        }

        .nav-card.gold::before {
            background: linear-gradient(
                135deg,
                rgba(197, 160, 89, 0.35),
                rgba(197, 160, 89, 0.1)
            );
        }

        .nav-card:hover {
            transform: translateY(-8px) scale(1.02);
            border-color: rgba(197, 160, 89, 0.5);
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
        }

        .nav-card:hover::before {
            opacity: 1;
        }

        .nav-card-icon {
            width: 56px;
            height: 56px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            position: relative;
            z-index: 1;
        }

        .nav-card.blue .nav-card-icon {
            background: rgba(27, 57, 106, 0.6);
            border: 1px solid rgba(27, 57, 106, 0.8);
        }

        .nav-card.gold .nav-card-icon {
            background: rgba(197, 160, 89, 0.25);
            border: 1px solid rgba(197, 160, 89, 0.5);
        }

        .nav-card-content {
            position: relative;
            z-index: 1;
            flex: 1;
        }

        .nav-card-title {
            font-size: 1.05rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin: 0 0 8px;
        }

        .nav-card-desc {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.65);
            line-height: 1.5;
            margin: 0;
        }

        .nav-card-arrow {
            position: absolute;
            bottom: 24px;
            right: 24px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.5);
            font-size: 0.85rem;
            transition: all 0.3s ease;
        }

        .nav-card:hover .nav-card-arrow {
            background: #c5a059;
            color: #fff;
            transform: translateX(3px);
        }

        /* ── PROFILES ──────────────────────────────────────────── */
        .profiles-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            margin-bottom: 64px;
        }

        .profile-card {
            background: rgba(10, 20, 50, 0.82);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.35s ease;
        }

        .profile-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.5);
            border-color: rgba(197, 160, 89, 0.35);
        }

        .profile-card-header {
            padding: 28px 36px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .profile-card.ingreso .profile-card-header {
            background: linear-gradient(
                135deg,
                rgba(27, 57, 106, 0.7),
                rgba(27, 57, 106, 0.4)
            );
            border-bottom: 1px solid rgba(27, 57, 106, 0.5);
        }

        .profile-card.egreso .profile-card-header {
            background: linear-gradient(
                135deg,
                rgba(197, 160, 89, 0.4),
                rgba(197, 160, 89, 0.15)
            );
            border-bottom: 1px solid rgba(197, 160, 89, 0.3);
        }

        .profile-card-header-icon {
            font-size: 2rem;
        }

        .profile-card-header h3 {
            font-size: 1.1rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0;
        }

        .profile-card-header p {
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.6);
            margin: 4px 0 0;
        }

        .profile-card-body {
            padding: 28px 36px;
        }

        .profile-card-body > p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
            margin: 0 0 20px;
            font-style: italic;
        }

        .profile-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .profile-list li {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.82);
            line-height: 1.5;
        }

        .profile-list li .bullet {
            flex-shrink: 0;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            margin-top: 1px;
        }

        .profile-card.ingreso .bullet {
            background: rgba(27, 57, 106, 0.6);
            border: 1px solid rgba(27, 57, 106, 0.9);
            color: #7ea8d8;
        }

        .profile-card.egreso .bullet {
            background: rgba(197, 160, 89, 0.2);
            border: 1px solid rgba(197, 160, 89, 0.5);
            color: #c5a059;
        }

        /* ── CONTACT ───────────────────────────────────────────── */
        .contact-section {
            background: rgba(10, 20, 50, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.2);
            border-radius: 24px;
            padding: 48px 56px;
            overflow: hidden;
            position: relative;
        }

        .contact-section::before {
            content: "";
            position: absolute;
            bottom: 0;
            right: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(to top, #c5a059, #1b396a);
            border-radius: 0 24px 24px 0;
        }

        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
            margin: 32px 0;
        }

        .contact-item {
            background: rgba(255, 255, 255, 0.07);
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: 16px;
            padding: 28px 32px;
            transition: all 0.3s ease;
        }

        .contact-item:hover {
            background: rgba(255, 255, 255, 0.09);
            border-color: rgba(197, 160, 89, 0.3);
        }

        .contact-item-role {
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            color: #c5a059;
            margin-bottom: 6px;
        }

        .contact-item-name {
            font-size: 1.05rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 14px;
        }

        .contact-item p {
            font-size: 0.875rem;
            color: rgba(255, 255, 255, 0.7);
            line-height: 1.7;
            margin: 0;
        }

        .contact-item a {
            color: #7ea8d8;
            text-decoration: none;
        }

        .contact-item a:hover {
            color: #c5a059;
        }

        .contact-links {
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
            padding-top: 24px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
        }

        .contact-link-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 22px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: rgba(255, 255, 255, 0.8);
            background: rgba(255, 255, 255, 0.06);
        }

        .contact-link-btn:hover {
            background: #c5a059;
            border-color: #c5a059;
            color: #fff;
            transform: translateY(-2px);
        }

        /* ── RESPONSIVE ────────────────────────────────────────── */
        @media (max-width: 1024px) {
            .nav-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .hero {
                padding: 140px 20px 40px;
            }
            .welcome-banner {
                padding: 32px 28px;
            }
            .welcome-banner::after {
                display: none;
            }
            .info-grid {
                grid-template-columns: 1fr;
            }
            .nav-grid {
                grid-template-columns: 1fr;
            }
            .profiles-grid {
                grid-template-columns: 1fr;
            }
            .contact-grid {
                grid-template-columns: 1fr;
            }
            .contact-section {
                padding: 32px 24px;
            }
            .glass-card {
                padding: 28px 24px;
            }
        }
    </style>

    <!-- ── HERO ───────────────────────────────────────────────── -->
    <div class="hero">
        <div class="hero-badge">
            <i class="fa-solid fa-graduation-cap"></i>
            Programa de Posgrado · TecNM Pachuca
        </div>
        <h1 class="hero-title">
            Doctorado en<br /><span>Ingeniería Mecánica</span>
        </h1>
        <div class="hero-divider"></div>
        <p class="hero-sub">
            Investigación de frontera · Generación de conocimiento · Formación
            líder
        </p>
    </div>

    <div class="page-wrap">
        <!-- ── BIENVENIDA ──────────────────────────────────────── -->
        <div class="welcome-banner">
            <div class="welcome-label">
                <i class="fa-solid fa-star"></i>&nbsp; Bienvenida
            </div>
            <p class="welcome-text">
                El <strong style="color:#c5a059;"
                    >Doctorado en Ingeniería Mecánica</strong
                > del Instituto Tecnológico de Pachuca les da la más cordial bienvenida.
                Nuestro programa está enfocado en la formación de investigadores de
                alto nivel capaces de generar y aplicar conocimiento innovador en
                las áreas de diseño, termofluidos y sistemas mecánicos avanzados,
                contribuyendo sustancialmente al desarrollo científico y tecnológico
                del país mediante soluciones vanguardistas.
            </p>
        </div>

        <!-- ── OBJETIVO + DIRIGIDO A ───────────────────────────── -->
        <h2 class="section-title">Información General</h2>
        <div class="info-grid">
            <div class="glass-card">
                <span class="card-icon">🎯</span>
                <h2>Objetivo General</h2>
                <p>
                    Formar investigadores independientes al más alto nivel,
                    capaces de generar y aplicar conocimiento original para el
                    avance de la Ingeniería Mecánica. Se busca desarrollar en
                    los estudiantes habilidades competitivas internacionalmente
                    para liderar proyectos de investigación y desarrollo
                    tecnológico, así como formar recursos humanos altamente
                    especializados.
                </p>
            </div>
            <div class="glass-card">
                <span class="card-icon">👥</span>
                <h2>Dirigido a</h2>
                <p>
                    El Programa está dirigido a egresados con grado de Maestría
                    en Ingeniería Mecánica o áreas afines, con profunda vocación
                    científica e interés en el desarrollo de proyectos de
                    investigación de frontera. Los candidatos deben mostrar alta
                    capacidad analítica, creatividad y potencial para realizar
                    aportaciones originales al conocimiento.
                </p>
            </div>
        </div>

        <!-- ── NAVIGATION CARDS ────────────────────────────────── -->
        <h2 class="section-title">Explora el Programa</h2>
        <div class="nav-grid">
            <a href={`${BASE}doctorado/plan-estudios`} class="nav-card blue">
                <div class="nav-card-icon">📋</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">Plan de Estudios</p>
                    <p class="nav-card-desc">
                        8 semestres · Seminarios de investigación · Trabajo
                        estrecho con comité tutoral y tesis de innovación.
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>

            <a href={`${BASE}doctorado/admision`} class="nav-card gold">
                <div class="nav-card-icon">📄</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">Admisión</p>
                    <p class="nav-card-desc">
                        Defensa de protocolo, evaluación de expediente y
                        certificación de inglés comprobable.
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>

            <a href={`${BASE}doctorado/lgac`} class="nav-card blue">
                <div class="nav-card-icon">🔬</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">LGAC</p>
                    <p class="nav-card-desc">
                        Líneas de investigación robustas: Diseño Mecánico y
                        Termofluidos, con avance sustentable y tecnología
                        puntera.
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>

            <a href={`${BASE}doctorado/nucleo-academico`} class="nav-card gold">
                <div class="nav-card-icon">👨‍🏫</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">Núcleo Académico</p>
                    <p class="nav-card-desc">
                        Cuerpo docente de élite con investigación activa y altos
                        niveles en el Sistema Nacional de Investigadores (SNI).
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>

            <a href={`${BASE}doctorado/vinculacion`} class="nav-card blue">
                <div class="nav-card-icon">🤝</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">Vinculación</p>
                    <p class="nav-card-desc">
                        Entorno de colaboración con centros públicos y sector
                        productivo para resolución de problemas reales.
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>

            <!-- Seminarios también existía en doctorado -->
            <a href={`${BASE}doctorado/seminarios`} class="nav-card gold">
                <div class="nav-card-icon">📺</div>
                <div class="nav-card-content">
                    <p class="nav-card-title">Seminarios</p>
                    <p class="nav-card-desc">
                        Revisa los seminarios y ponencias magistrales para el
                        fortalecimiento del programa de Doctorado de Mecánica.
                    </p>
                </div>
                <div class="nav-card-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </div>
            </a>
        </div>

        <!-- ── PERFILES ────────────────────────────────────────── -->
        <h2 class="section-title">Perfiles</h2>
        <div class="profiles-grid">
            <!-- Ingreso -->
            <div class="profile-card ingreso">
                <div class="profile-card-header">
                    <div class="profile-card-header-icon">🎓</div>
                    <div>
                        <h3>Perfil de Ingreso</h3>
                        <p>Requisitos del aspirante</p>
                    </div>
                </div>
                <div class="profile-card-body">
                    <p>
                        Se requiere del aspirante a este Programa de Doctorado:
                    </p>
                    <ul class="profile-list">
                        <li>
                            <span class="bullet"
                                ><i class="fa-solid fa-check"></i></span
                            >
                            Poseer el Grado de Maestría en Ingeniería Mecánica o áreas
                            afines a las ciencias de la ingeniería.
                        </li>
                        <li>
                            <span class="bullet"
                                ><i class="fa-solid fa-check"></i></span
                            >
                            Tener capacidad comprobada para el trabajo de investigación
                            independiente y comprensión avanzada de literatura científica
                            en inglés.
                        </li>
                        <li>
                            <span class="bullet"
                                ><i class="fa-solid fa-check"></i></span
                            >
                            Mostrar aptitud para plantear y resolver problemas complejos
                            mediante modelos matemáticos y simulación numérica.
                        </li>
                        <li>
                            <span class="bullet"
                                ><i class="fa-solid fa-check"></i></span
                            >
                            Tener habilidades de pensamiento crítico, redacción científica
                            y expresión clara de ideas complejas.
                        </li>
                        <li>
                            <span class="bullet"
                                ><i class="fa-solid fa-check"></i></span
                            >
                            Demostrar interés y compromiso total con el desarrollo
                            de la ciencia y tecnología orientada a las necesidades
                            nacionales.
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Egreso -->
            <div class="profile-card egreso">
                <div class="profile-card-header">
