---
import Layout from "../../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL || "/";
---

<Layout title="Proceso de Admisión - Doctorado en Ingeniería Mecánica">
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            /* Same background as mechanics master/doctorate */
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            position: relative;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
        }

        .doctorado-container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            padding: 150px 20px 60px 20px;
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .doctorado-title {
            text-align: center;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: #ffffff;
            text-transform: uppercase;
            letter-spacing: 4px;
            margin-bottom: 60px;
            text-shadow: 0 0 20px rgba(27, 57, 106, 0.6);
        }

        /* Glassmorphism Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.94);
            backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid rgba(255, 255, 255, 0.125);
            border-radius: 24px;
            padding: clamp(30px, 5vw, 60px);
            margin-bottom: 40px;
            width: 100%;
            max-width: 1100px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
            border-top: 10px solid #1b396a;
            transition: all 0.4s ease;
        }

        .glass-card.gold-accent {
            border-top-color: #c5a059;
        }

        .glass-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
            background: rgba(255, 255, 255, 0.97);
        }

        .glass-card h2 {
            font-size: 2.2rem;
            color: #1b396a;
            margin-bottom: 30px;
            text-align: center;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .glass-card.gold-accent h2 {
            color: #c5a059;
        }

        .iframe-container {
            position: relative;
            width: 100%;
            height: 800px;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid rgba(0, 0, 0, 0.1);
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 0.05);
        }

        .iframe-container iframe {
            width: 100%;
            height: 100%;
            border: none;
            background-color: white;
        }

        .download-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-top: 30px;
            width: 100%;
        }

        .download-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: #1b396a;
            color: white !important;
            padding: 18px 25px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 700;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            text-align: center;
            border: 1px solid transparent;
        }

        .download-btn i {
            font-size: 1.4rem;
        }

        .download-btn:hover {
            background: rgba(255, 255, 255, 0.9);
            color: #c5a059 !important;
            border-color: #c5a059;
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(197, 160, 89, 0.2);
        }

        @media (max-width: 992px) {
            .doctorado-container {
                padding: 120px 20px 40px;
            }
            .glass-card {
                padding: 30px;
            }
        }

        @media (max-width: 768px) {
            .doctorado-title {
                font-size: 2.2rem;
                margin-bottom: 40px;
            }
            .iframe-container {
                height: 500px;
            }
            .glass-card h2 {
                font-size: 1.8rem;
            }
            .download-btn {
                padding: 15px 20px;
                font-size: 1rem;
            }
        }
    </style>

    <div class="doctorado-container">
        <h1 class="doctorado-title">Proceso de Admisión</h1>

        <div class="glass-card">
            <h2>Convocatoria</h2>
            <div class="iframe-container">
                <iframe
                    src={`${BASE}pdf/Convocatoria doctorado 1.2.pdf`}
                    title="Convocatoria Doctorado en Ingeniería Mecánica"
                ></iframe>
            </div>
        </div>

        <div class="glass-card gold-accent">
            <h2>Documentos de Descarga</h2>
            <div class="download-grid">
                <a
                    href={`${BASE}pdf/admision_doctorado_20251/Formato anexo-admisión.docx`}
                    class="download-btn"
                    download
                >
                    <i class="fa-solid fa-file-word"></i> Formato Admisión
                </a>
                <a
                    href={`${BASE}pdf/admision_doctorado_20251/Formato Anexo-protocolo.docx`}
                    class="download-btn"
                    download
                >
                    <i class="fa-solid fa-file-word"></i> Formato Protocolo
                </a>
                <a
                    href={`${BASE}pdf/admision_doctorado_20251/Anexo 1.docx`}
                    class="download-btn"
                    download
                >
                    <i class="fa-solid fa-file-word"></i> Anexo 1
                </a>
            </div>
        </div>
    </div>
</Layout>
