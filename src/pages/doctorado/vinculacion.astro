                            >
                            <td data-label="Directores" class="directors-text"
                                >Dr. Edgar E. Vera Cárdenas<br />Dr. José S.
                                Pacheco (UAEH)</td
                            >
                        </tr>
                        <tr>
                            <td data-label="Alumno"
                                ><span class="student-name"
                                    >Marrón Ramírez Luis E.</span
                                ><small class="text-slate-500">Segundo</small
                                ></td
                            >
                            <td data-label="Título" class="thesis-title"
                                >Optimización de transferencia de calor en
