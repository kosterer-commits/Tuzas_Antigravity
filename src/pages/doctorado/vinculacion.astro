                            >
                            <td data-label="Directores" class="directors-text"
                                >Dr. Juan Serrano Arellano<br />Dr. Francisco N.
                                Demesa López</td
                            >
                        </tr>
                        <tr>
                            <td data-label="Alumno"
                                ><span class="student-name"
                                    >Olvera Alvarado A. Evanan</span
                                ><small class="text-slate-500">Tercero</small
