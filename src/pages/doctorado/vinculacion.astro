                            >
                        </tr>
                        <tr>
                            <td data-label="Alumno"
                                ><span class="student-name"
                                    >Hernández López María I.</span
                                ><small class="text-slate-500">Cuarto</small
                                ></td
                            >
                            <td data-label="Título" class="thesis-title"
                                >Modelación numérica del flujo de aire
