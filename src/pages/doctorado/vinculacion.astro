                            >
                            <td data-label="Directores" class="directors-text"
                                >Dr. Edgar E. Vera Cárdenas<br />Dr. Juan M.
                                Carmona (CIDESI)</td
                            >
                        </tr>
                        <tr>
                            <td data-label="Alumno"
                                ><span class="student-name"
                                    >Ibáñez Juárez Carlos R.</span
                                ><small class="text-slate-500">Séptimo</small
                                ></td
                            >
                            <td data-label="Título" class="thesis-title"
                                >Caracterización mecánica y tribológica de
                                polímeros biobasados</td
                            >
                            <td data-label="Directores" class="directors-text"
                                >Dr. Edgar E. Vera Cárdenas<br />Dr. Mauricio
