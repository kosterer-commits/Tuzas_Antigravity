---
import Layout from "../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
const BASE_CLEAN = BASE.replace(/\/$/, "");

// ── Build-time document enumeration ───────────────────────────────────────
// Glob all files in the SGI archives folder
const allFiles = import.meta.glob("/public/archives/SGI/**/*", {
  eager: false,
});

type DocFile = { name: string; url: string; icon: string; ext: string };
type DocGroup = { groupName: string; files: DocFile[] };

function fileName(path: string): string {
  return path.split("/").pop() || path;
}

function fileIcon(name: string): string {
  const ext = name.split(".").pop()?.toLowerCase() ?? "";
  if (ext === "pdf") return "📄";
  if (ext === "docx" || ext === "doc") return "📝";
  if (ext === "xlsx" || ext === "xls") return "📊";
  if (ext === "ppt" || ext === "pptx") return "📊";
  return "📁";
}

// Get all files belonging EXACTLY to one top-level SGI folder (exact folder name match)
function getFilesForFolder(exactFolderName: string): DocFile[] {
  const prefix = `/public/archives/SGI/${exactFolderName}/`;
  return Object.keys(allFiles)
    .filter((k) => {
      const name = fileName(k).toLowerCase();
      return (
        k.startsWith(prefix) &&
        fileName(k).includes(".") &&
        !fileName(k).startsWith(".") &&
        name !== "desktop.ini" &&
        name !== "thumbs.db" &&
        !name.startsWith("~")
      );
    })
    .map((k) => ({
      name: fileName(k),
      url: k.replace(/^\/public/, ""),
      icon: fileIcon(fileName(k)),
      ext: (fileName(k).split(".").pop() ?? "").toUpperCase(),
    }))
    .sort((a, b) => a.name.localeCompare(b.name));
}

// Group files by their immediate parent subfolder within the section folder
function groupFiles(files: DocFile[], exactFolderName: string): DocGroup[] {
  const prefix = `/archives/SGI/${exactFolderName}/`;
  const map: Record<string, DocFile[]> = {};

  files.forEach((f) => {
    // f.url = /archives/SGI/<folder>/<optional-subfolder>/<file>
    const afterPrefix = f.url.replace(prefix, "");
    const parts = afterPrefix.split("/");
    // If there's a subfolder (parts.length > 1), use it as group name; else "FICHA DE PROCESO"
    const groupName = parts.length > 1 ? parts[0] : "FICHA DE PROCESO";
    if (!map[groupName]) map[groupName] = [];
    map[groupName].push(f);
  });

  // Sort groups: put FICHA DE PROCESO first, then alphabetically
  return Object.entries(map)
    .sort(([a], [b]) => {
      if (a === "FICHA DE PROCESO") return -1;
      if (b === "FICHA DE PROCESO") return 1;
      return a.localeCompare(b);
    })
    .map(([groupName, files]) => ({ groupName, files }));
}

// ── Process definitions — each maps to EXACT folder name on disk ──────────
const processDefs = [
  {
    id: "academico",
    icon: "🎓",
    title: "Proceso Estratégico Académico",
    color: "blue",
    folder: "Proceso Académico", // Exactly as on disk (capital P, accent)
    norm: "ISO 9001",
  },
  {
    id: "recursos",
    icon: "💰",
    title: "Proceso Estratégico Administración de Recursos",
    color: "gold",
    folder: "proceso estrategico administracion de recursos",
    norm: "ISO 9001",
  },
  {
    id: "calidad",
    icon: "⭐",
    title: "Proceso Estratégico de Calidad",
    color: "blue",
    folder: "proceso estrategico de calidad",
    norm: "ISO 9001",
  },
  {
    id: "planeacion",
    icon: "📋",
    title: "Proceso Estratégico de Planeación",
    color: "gold",
    folder: "proceso estrategico de planeacion",
    norm: "ISO 9001",
  },
  {
    id: "vinculacion",
    icon: "🤝",
    title: "Proceso Estratégico de Vinculación",
    color: "blue",
    folder: "proceso estrategico de vinculacion",
    norm: "ISO 9001",
  },
  {
    id: "ambiental",
    icon: "🌿",
    title: "Proceso Estratégico Ambiental",
    color: "gold",
    folder: "Proceso Ambiental", // Capital P — empty folder (docs coming soon)
    norm: "ISO 14001",
  },
  {
    id: "seguridad",
    icon: "🔒",
    title: "Proceso Estratégico de Seguridad",
    color: "blue",
    folder: "", // No folder yet
    norm: "ISO 45001",
  },
  {
    id: "energia",
    icon: "⚡",
    title: "Proceso Estratégico de Energía",
    color: "gold",
    folder: "", // No folder yet
    norm: "ISO 50001",
  },
  {
    id: "referencias",
    icon: "📚",
    title: "Documentos de Referencia",
    color: "blue",
    folder: "documentos de referencia",
    norm: "Normativos",
  },
];

const processes = processDefs.map((p) => {
  const files = p.folder ? getFilesForFolder(p.folder) : [];
  return { ...p, files, groups: groupFiles(files, p.folder) };
});

const manualFiles = getFilesForFolder("manual de calidad");
const manualGroups = groupFiles(manualFiles, "manual de calidad");
---

<Layout title="Sistema de Gestión Integrado - TecNM Pachuca">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700;900&display=swap");

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      background:
        linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.75) 0%,
          rgba(5, 15, 40, 0.9) 35%,
          rgba(5, 15, 40, 1) 100%
        ),
        url("/images/Fondos/Entrada.jpg");
      background-size: cover;
      background-position: center top;
      background-attachment: fixed;
      background-repeat: no-repeat;
      font-family: "Roboto", sans-serif;
      color: #fff;
    }

    /* ── HERO ────────────────────────────────────────────────────── */
    .hero {
      text-align: center;
      padding: 160px 20px 70px;
    }
    .hero-badges {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 28px;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(197, 160, 89, 0.12);
      border: 1px solid rgba(197, 160, 89, 0.4);
      color: #c5a059;
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 6px 16px;
      border-radius: 50px;
      backdrop-filter: blur(8px);
    }
    .hero-title {
      font-size: clamp(2rem, 5vw, 3.8rem);
      font-weight: 900;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 3px;
      line-height: 1.1;
      margin: 0 auto 12px;
      max-width: 900px;
      text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
    }
    .hero-title span {
      color: #c5a059;
    }
    .hero-divider {
      width: 80px;
      height: 4px;
      background: linear-gradient(to right, transparent, #c5a059, transparent);
      margin: 20px auto 24px;
      border-radius: 4px;
    }
    .hero-sub {
      color: rgba(255, 255, 255, 0.7);
      font-size: 1rem;
      letter-spacing: 0.05em;
    }

    /* ── PAGE WRAP ───────────────────────────────────────────────── */
    .page-wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 24px 100px;
    }

    /* ── SEARCH BAR ──────────────────────────────────────────────── */
    .search-wrap {
      display: flex;
      align-items: center;
      gap: 14px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(197, 160, 89, 0.3);
      border-radius: 60px;
      padding: 14px 24px;
      margin-bottom: 60px;
      backdrop-filter: blur(12px);
      transition: border-color 0.3s;
    }
    .search-wrap:focus-within {
      border-color: rgba(197, 160, 89, 0.7);
    }
    .search-wrap span {
      font-size: 1.2rem;
      opacity: 0.6;
    }
    #sgi-search {
      background: none;
      border: none;
      outline: none;
      color: #fff;
      font-size: 1rem;
      font-family: "Roboto", sans-serif;
      width: 100%;
    }
    #sgi-search::placeholder {
      color: rgba(255, 255, 255, 0.35);
    }

    /* ── SECTION TITLE ───────────────────────────────────────────── */
    .section-title {
      text-align: center;
      color: #fff;
      font-size: clamp(1.3rem, 2.5vw, 1.8rem);
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin: 0 0 40px;
    }
    .section-title::after {
      content: "";
      display: block;
      width: 50px;
      height: 3px;
      background: #c5a059;
      margin: 12px auto 0;
      border-radius: 2px;
    }

    /* ── PROCESS GRID ────────────────────────────────────────────── */
    .process-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-bottom: 60px;
    }

    /* ── ACCORDION CARD ──────────────────────────────────────────── */
    .proc-card {
      background: rgba(10, 20, 50, 0.78);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      overflow: hidden;
      transition:
        border-color 0.3s,
        box-shadow 0.3s;
    }
    .proc-card:hover {
      border-color: rgba(197, 160, 89, 0.35);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
    }
    .proc-card.open {
      border-color: rgba(197, 160, 89, 0.5);
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.5);
    }

    .proc-header {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 24px 26px;
      cursor: pointer;
      user-select: none;
      transition: background 0.25s;
    }
    .proc-header:hover {
      background: rgba(255, 255, 255, 0.04);
    }

    .proc-icon {
      font-size: 1.8rem;
      width: 52px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      flex-shrink: 0;
    }
    .proc-card.blue .proc-icon {
      background: rgba(27, 57, 106, 0.6);
      border: 1px solid rgba(60, 100, 180, 0.4);
    }
    .proc-card.gold .proc-icon {
      background: rgba(197, 160, 89, 0.18);
      border: 1px solid rgba(197, 160, 89, 0.4);
    }

    .proc-meta {
      flex: 1;
      min-width: 0;
    }
    .proc-norm {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #c5a059;
      margin-bottom: 4px;
    }
    .proc-title {
      font-size: 0.9rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.3;
      margin: 0 0 6px;
    }
    .proc-count {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.45);
    }

    .proc-toggle {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      color: rgba(255, 255, 255, 0.5);
      transition: all 0.3s;
      flex-shrink: 0;
    }
    .proc-card.open .proc-toggle {
      background: rgba(197, 160, 89, 0.3);
      color: #c5a059;
      transform: rotate(180deg);
    }

    .proc-body {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.45s cubic-bezier(0.4, 0, 0.2, 1);
      border-top: 1px solid transparent;
    }
    .proc-card.open .proc-body {
      max-height: 3000px;
      border-top-color: rgba(255, 255, 255, 0.07);
    }
    .proc-body-inner {
      padding: 20px 26px 26px;
    }

    .proc-empty {
      text-align: center;
      padding: 24px;
      color: rgba(255, 255, 255, 0.35);
      font-size: 0.85rem;
    }
    .soon-badge {
      display: inline-block;
      background: rgba(197, 160, 89, 0.1);
      border: 1px solid rgba(197, 160, 89, 0.3);
      color: #c5a059;
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 20px;
      margin-bottom: 8px;
    }

    /* ── DOC GROUPS & ITEMS ──────────────────────────────────────── */
    .doc-group {
      margin-bottom: 16px;
    }
    .doc-group-title {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: #c5a059;
      padding: 6px 12px;
      border-radius: 8px;
      background: rgba(197, 160, 89, 0.08);
      border-left: 3px solid rgba(197, 160, 89, 0.5);
      margin-bottom: 8px;
      word-break: break-word;
    }
    .doc-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .doc-item {
      display: flex;
      align-items: center;
    }
    .doc-item a {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.82rem;
      line-height: 1.4;
      padding: 8px 10px;
      border-radius: 8px;
      transition: all 0.2s;
      width: 100%;
    }
    .doc-item a:hover {
      background: rgba(255, 255, 255, 0.06);
      color: #fff;
    }
    .doc-icon {
      font-size: 0.9rem;
      flex-shrink: 0;
    }
    .doc-name {
      flex: 1;
      word-break: break-word;
    }
    .doc-ext {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 2px 7px;
      border-radius: 4px;
      flex-shrink: 0;
    }
    .doc-ext.pdf {
      background: rgba(220, 53, 69, 0.2);
      color: #ff7b86;
    }
    .doc-ext.docx,
    .doc-ext.doc {
      background: rgba(30, 130, 220, 0.2);
      color: #7ec8ff;
    }
    .doc-ext.xlsx,
    .doc-ext.xls {
      background: rgba(40, 167, 69, 0.2);
      color: #7fffb0;
    }
    .doc-ext.ppt,
    .doc-ext.pptx {
      background: rgba(255, 140, 0, 0.2);
      color: #ffd080;
    }

    /* ── MANUAL CARD ─────────────────────────────────────────────── */
    .manual-card {
      background: linear-gradient(
        135deg,
        rgba(27, 57, 106, 0.85),
        rgba(5, 15, 40, 0.9)
      );
      backdrop-filter: blur(20px);
      border: 1px solid rgba(197, 160, 89, 0.3);
      border-radius: 24px;
      padding: 44px 52px;
      margin-bottom: 60px;
      position: relative;
      overflow: hidden;
    }
    .manual-card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 6px;
      height: 100%;
      background: linear-gradient(to bottom, #c5a059, #1b396a);
      border-radius: 24px 0 0 24px;
    }
    .manual-card-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 32px;
    }
    .manual-card-icon {
      width: 64px;
      height: 64px;
      background: rgba(197, 160, 89, 0.18);
      border: 1px solid rgba(197, 160, 89, 0.5);
      border-radius: 18px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
    }
    .manual-card-header h2 {
      font-size: 1.3rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #fff;
      margin: 0 0 4px;
    }
    .manual-card-header p {
      font-size: 0.8rem;
      color: #c5a059;
      margin: 0;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .manual-doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 10px;
    }
    .manual-doc-item a {
      display: flex;
      align-items: center;
      gap: 12px;
      text-decoration: none;
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.85rem;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 10px;
      transition: all 0.25s;
    }
    .manual-doc-item a:hover {
      background: rgba(197, 160, 89, 0.12);
      border-color: rgba(197, 160, 89, 0.35);
      color: #fff;
    }

    /* ── SEARCH HIDE ─────────────────────────────────────────────── */
    .doc-item.hidden-doc {
      display: none;
    }
    .doc-group.all-hidden {
      display: none;
    }

    /* ── RESPONSIVE ──────────────────────────────────────────────── */
    @media (max-width: 1024px) {
      .process-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (max-width: 640px) {
      .hero {
        padding: 130px 16px 50px;
      }
      .process-grid {
        grid-template-columns: 1fr;
      }
      .manual-card {
        padding: 28px 24px;
      }
      .manual-card::before {
        display: none;
      }
    }
  </style>

  <!-- ── HERO ────────────────────────────────────────────────────── -->
  <div class="hero">
    <div class="hero-badges">
      <span class="hero-badge">🏆 ISO 9001:2015</span>
      <span class="hero-badge">🌿 ISO 14001:2015</span>
      <span class="hero-badge">🔒 ISO 45001:2018</span>
      <span class="hero-badge">⚡ ISO 50001:2018</span>
    </div>
    <h1 class="hero-title">Sistema de <span>Gestión Integrado</span></h1>
    <div class="hero-divider"></div>
    <p class="hero-sub">
      Instituto Tecnológico de Pachuca · TecNM · Documentación y Procesos
      Estratégicos
    </p>
  </div>

  <div class="page-wrap">
    <!-- ── SEARCH ────────────────────────────────────────────────── -->
    <div class="search-wrap">
      <span>🔍</span>
      <input
        id="sgi-search"
        type="text"
        placeholder="Buscar documento por nombre..."
        autocomplete="off"
      />
    </div>

    <!-- ── MANUAL DEL SGI ────────────────────────────────────────── -->
    <div class="manual-card">
      <div class="manual-card-header">
        <div class="manual-card-icon">📖</div>
        <div>
          <h2>Manual del Sistema de Gestión Integrado</h2>
          <p>Documento maestro · {manualFiles.length} archivo(s)</p>
        </div>
      </div>
      <div class="manual-doc-grid">
        {
          manualGroups
            .flatMap((g) => g.files)
            .map((f) => (
              <div
                class="manual-doc-item doc-item"
                data-doc-name={f.name.toLowerCase()}
              >
                <a
                  href={`${BASE_CLEAN}${f.url}`}
                  target="_blank"
                  rel="noopener"
                >
                  <span class="doc-icon">{f.icon}</span>
                  <span class="doc-name">{f.name}</span>
                  <span class={`doc-ext ${f.ext.toLowerCase()}`}>{f.ext}</span>
                </a>
              </div>
            ))
        }
      </div>
    </div>

    <!-- ── PROCESOS ESTRATÉGICOS ─────────────────────────────────── -->
    <h2 class="section-title">Procesos Estratégicos</h2>

    <div class="process-grid" id="process-grid">
      {
        processes.map((proc) => (
          <div
            class={`proc-card ${proc.color}`}
            id={`card-${proc.id}`}
            data-process-id={proc.id}
          >
            <div
              class="proc-header"
              onclick={`toggleProc('${proc.id}')`}
              role="button"
              tabindex="0"
            >
              <div class="proc-icon">{proc.icon}</div>
              <div class="proc-meta">
                <div class="proc-norm">{proc.norm}</div>
                <div class="proc-title">{proc.title}</div>
                <div class="proc-count">
                  {proc.files.length > 0
                    ? `${proc.files.length} documento(s)`
                    : "Sin documentos"}
                </div>
              </div>
              <div class="proc-toggle">▼</div>
            </div>

            <div class="proc-body">
              <div class="proc-body-inner">
                {proc.files.length > 0 ? (
                  proc.groups.map((g) => (
                    <div class="doc-group">
                      {proc.groups.length > 1 && (
                        <div class="doc-group-title">{g.groupName}</div>
                      )}
                      <ul class="doc-list">
                        {g.files.map((f) => (
                          <li
                            class="doc-item"
                            data-doc-name={f.name.toLowerCase()}
                          >
                            <a
                              href={`${BASE_CLEAN}${f.url}`}
                              target="_blank"
                              rel="noopener"
                            >
                              <span class="doc-icon">{f.icon}</span>
                              <span class="doc-name">{f.name}</span>
                              <span class={`doc-ext ${f.ext.toLowerCase()}`}>
                                {f.ext}
                              </span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))
                ) : (
                  <div class="proc-empty">
                    <div class="soon-badge">Próximamente</div>
                    <p>
                      Los documentos de este proceso serán publicados
                      próximamente.
                    </p>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <script>
    function toggleProc(id) {
      var card = document.getElementById("card-" + id);
      if (!card) return;
      card.classList.toggle("open");
    }

    document.querySelectorAll(".proc-header").forEach(function (header) {
      header.addEventListener("keydown", function (e) {
        if (e.key === "Enter" || e.key === " ") header.click();
      });
    });

    var searchInput = document.getElementById("sgi-search");
    if (searchInput) {
      searchInput.addEventListener("input", function () {
        var query = searchInput.value.toLowerCase().trim();
        var allItems = document.querySelectorAll(".doc-item[data-doc-name]");

        allItems.forEach(function (item) {
          var name = item.getAttribute("data-doc-name") || "";
          var hidden = query.length > 0 && !name.includes(query);
          item.classList.toggle("hidden-doc", hidden);
        });

        // Hide empty doc-groups
        document.querySelectorAll(".doc-group").forEach(function (group) {
          var visible = group.querySelectorAll(".doc-item:not(.hidden-doc)");
          group.classList.toggle(
            "all-hidden",
            query.length > 0 && visible.length === 0,
          );
        });

        if (query.length > 0) {
          document
            .querySelectorAll(".proc-card[data-process-id]")
            .forEach(function (card) {
              var visibleItems = card.querySelectorAll(
                ".doc-item[data-doc-name]:not(.hidden-doc)",
              );
              card.classList.toggle("open", visibleItems.length > 0);
            });
        } else {
          document.querySelectorAll(".proc-card").forEach(function (c) {
            c.classList.remove("open");
          });
        }
      });
    }

    window.toggleProc = toggleProc;
  </script>
</Layout>
