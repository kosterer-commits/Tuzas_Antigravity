---
import Layout from "../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
const BASE_CLEAN = BASE.replace(/\/$/, "");

// ── Build-time document enumeration ───────────────────────────────────────
const allFiles = import.meta.glob("/public/archives/SGI/**/*", { eager: false });

type DocFile = { name: string; url: string; icon: string; ext: string };
type DocGroup = { groupName: string; files: DocFile[] };

function fileName(path: string): string {
  return path.split("/").pop() || path;
}

function fileIcon(name: string): string {
  const ext = name.split(".").pop()?.toLowerCase() ?? "";
  if (ext === "pdf") return "📄";
  if (ext === "docx" || ext === "doc") return "📝";
  if (ext === "xlsx" || ext === "xls") return "📊";
  if (ext === "ppt" || ext === "pptx") return "📊";
  return "📎";
}

function getFilesForFolder(exactFolderName: string): DocFile[] {
  const prefix = `/public/archives/SGI/${exactFolderName}/`;
  return Object.keys(allFiles)
    .filter((k) => {
      const name = fileName(k).toLowerCase();
      return (
        k.startsWith(prefix) &&
        fileName(k).includes(".") &&
        !fileName(k).startsWith(".") &&
        name !== "desktop.ini" &&
        name !== "thumbs.db" &&
        !name.startsWith("~")
      );
    })
    .map((k) => ({
      name: fileName(k),
      url: k.replace(/^\/public/, ""),
      icon: fileIcon(fileName(k)),
      ext: (fileName(k).split(".").pop() ?? "").toUpperCase(),
    }))
    .sort((a, b) => a.name.localeCompare(b.name));
}

function groupFiles(files: DocFile[], exactFolderName: string): DocGroup[] {
  const prefix = `/archives/SGI/${exactFolderName}/`;
  const map: Record<string, DocFile[]> = {};
  files.forEach((f) => {
    const afterPrefix = f.url.replace(prefix, "");
    const parts = afterPrefix.split("/");
    const groupName = parts.length > 1 ? parts[0] : "Documentos";
    if (!map[groupName]) map[groupName] = [];
    map[groupName].push(f);
  });
  return Object.entries(map)
    .sort(([a], [b]) => {
      if (a === "Documentos") return -1;
      if (b === "Documentos") return 1;
      return a.localeCompare(b);
    })
    .map(([groupName, files]) => ({ groupName, files }));
}

const processDefs = [
  { id: "academico",    icon: "🎓", title: "Proceso Estratégico Académico",               color: "blue", folder: "Proceso Académico",                             norm: "ISO 9001"   },
  { id: "recursos",    icon: "💰", title: "P.E. Administración de Recursos",              color: "gold", folder: "proceso estrategico administracion de recursos",  norm: "ISO 9001"   },
  { id: "calidad",     icon: "⭐", title: "Proceso Estratégico de Calidad",               color: "blue", folder: "proceso estrategico de calidad",                  norm: "ISO 9001"   },
  { id: "planeacion",  icon: "📋", title: "Proceso Estratégico de Planeación",            color: "gold", folder: "proceso estrategico de planeacion",               norm: "ISO 9001"   },
  { id: "vinculacion", icon: "🤝", title: "Proceso Estratégico de Vinculación",           color: "blue", folder: "proceso estrategico de vinculacion",              norm: "ISO 9001"   },
  { id: "ambiental",   icon: "🌿", title: "Proceso Estratégico Ambiental",                color: "gold", folder: "Proceso Ambiental",                              norm: "ISO 14001"  },
  { id: "seguridad",   icon: "🔒", title: "Proceso Estratégico de Seguridad",             color: "blue", folder: "",                                               norm: "ISO 45001"  },
  { id: "energia",     icon: "⚡", title: "Proceso Estratégico de Energía",               color: "gold", folder: "",                                               norm: "ISO 50001"  },
  { id: "referencias", icon: "📚", title: "Documentos de Referencia",                     color: "blue", folder: "documentos de referencia",                       norm: "Normativos" },
];

const processes = processDefs.map((p) => {
  const files = p.folder ? getFilesForFolder(p.folder) : [];
  return { ...p, files, groups: groupFiles(files, p.folder) };
});

const manualFiles = getFilesForFolder("manual de calidad");
const manualGroups = groupFiles(manualFiles, "manual de calidad");
---

<Layout title="Sistema de Gestión Integrado - TecNM Pachuca">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;700;900&display=swap");
    * { box-sizing: border-box; }

    body {
      margin: 0; padding: 0; min-height: 100vh;
      background:
        linear-gradient(to bottom, rgba(0,0,0,0.75) 0%, rgba(5,15,40,0.9) 35%, rgba(5,15,40,1) 100%),
        url("/images/Fondos/Entrada.jpg");
      background-size: cover; background-position: center top;
      background-attachment: fixed; font-family: "Roboto", sans-serif; color: #fff;
    }

    /* HERO */
    .hero { text-align: center; padding: 160px 20px 70px; }
    .hero-badges { display:flex; justify-content:center; flex-wrap:wrap; gap:10px; margin-bottom:28px; }
    .hero-badge {
      display:inline-flex; align-items:center; gap:6px;
      background:rgba(197,160,89,0.12); border:1px solid rgba(197,160,89,0.4);
      color:#c5a059; font-size:0.65rem; font-weight:700; letter-spacing:0.18em;
      text-transform:uppercase; padding:6px 16px; border-radius:50px; backdrop-filter:blur(8px);
    }
    .hero-title {
      font-size:clamp(2rem,5vw,3.8rem); font-weight:900; color:#fff;
      text-transform:uppercase; letter-spacing:3px; line-height:1.1;
      margin:0 auto 12px; max-width:900px; text-shadow:0 4px 30px rgba(0,0,0,0.5);
    }
    .hero-title span { color:#c5a059; }
    .hero-divider { width:80px; height:4px; background:linear-gradient(to right,transparent,#c5a059,transparent); margin:20px auto 24px; border-radius:4px; }
    .hero-sub { color:rgba(255,255,255,0.7); font-size:1rem; letter-spacing:0.05em; }

    /* PAGE */
    .page-wrap { max-width:1280px; margin:0 auto; padding:0 24px 100px; }

    /* SEARCH */
    .search-wrap {
      display:flex; align-items:center; gap:14px;
      background:rgba(255,255,255,0.06); border:1px solid rgba(197,160,89,0.3);
      border-radius:60px; padding:14px 24px; margin-bottom:60px;
      backdrop-filter:blur(12px); transition:border-color 0.3s;
    }
    .search-wrap:focus-within { border-color:rgba(197,160,89,0.7); }
    .search-wrap span { font-size:1.2rem; opacity:0.6; }
    #sgi-search {
      background:none; border:none; outline:none; color:#fff;
      font-size:1rem; font-family:"Roboto",sans-serif; width:100%;
    }
    #sgi-search::placeholder { color:rgba(255,255,255,0.35); }

    /* SECTION TITLE */
    .section-title {
      text-align:center; color:#fff;
      font-size:clamp(1.3rem,2.5vw,1.8rem); font-weight:800;
      text-transform:uppercase; letter-spacing:2px; margin:0 0 40px;
    }
    .section-title::after { content:""; display:block; width:50px; height:3px; background:#c5a059; margin:12px auto 0; border-radius:2px; }

    /* PROCESS GRID */
    .process-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:60px; }

    .proc-card {
      background:rgba(10,20,50,0.78); backdrop-filter:blur(20px);
      border:1px solid rgba(255,255,255,0.1); border-radius:20px;
      cursor:pointer; transition:all 0.3s; outline:none; padding:0;
      text-align:left; width:100%;
    }
    .proc-card:hover, .proc-card:focus-visible {
      border-color:rgba(197,160,89,0.5);
      box-shadow:0 12px 40px rgba(0,0,0,0.5);
      transform:translateY(-4px);
    }
    .proc-inner { display:flex; align-items:center; gap:16px; padding:26px; }
    .proc-icon { font-size:1.8rem; width:54px; height:54px; display:flex; align-items:center; justify-content:center; border-radius:14px; flex-shrink:0; }
    .proc-card.blue .proc-icon { background:rgba(27,57,106,0.6); border:1px solid rgba(60,100,180,0.4); }
    .proc-card.gold .proc-icon { background:rgba(197,160,89,0.18); border:1px solid rgba(197,160,89,0.4); }
    .proc-meta { flex:1; min-width:0; }
    .proc-norm { font-size:0.6rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; color:#c5a059; margin-bottom:4px; }
    .proc-title { font-size:0.88rem; font-weight:700; color:#fff; line-height:1.3; margin:0 0 8px; }
    .proc-chip {
      display:inline-flex; align-items:center; gap:5px;
      background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15);
      border-radius:20px; padding:3px 12px; font-size:0.72rem; color:rgba(255,255,255,0.7);
      transition:background 0.3s;
    }
    .proc-chip.empty { opacity:0.45; }
    .proc-card:hover .proc-chip:not(.empty) { background:rgba(197,160,89,0.2); border-color:rgba(197,160,89,0.4); color:#fff; }
    .proc-arrow { color:rgba(255,255,255,0.3); font-size:1rem; flex-shrink:0; transition:transform 0.3s, color 0.3s; }
    .proc-card:hover .proc-arrow { color:#c5a059; transform:translateX(5px); }

    /* MANUAL CARD */
    .manual-card {
      background:linear-gradient(135deg,rgba(27,57,106,0.85),rgba(5,15,40,0.9));
      backdrop-filter:blur(20px); border:1px solid rgba(197,160,89,0.3);
      border-radius:24px; padding:44px 52px; margin-bottom:60px;
      position:relative; overflow:hidden;
    }
    .manual-card::before { content:""; position:absolute; top:0; left:0; width:6px; height:100%; background:linear-gradient(to bottom,#c5a059,#1b396a); border-radius:24px 0 0 24px; }
    .manual-card-header { display:flex; align-items:center; gap:20px; margin-bottom:32px; }
    .manual-card-icon { width:64px; height:64px; background:rgba(197,160,89,0.18); border:1px solid rgba(197,160,89,0.5); border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2rem; }
    .manual-card-header h2 { font-size:1.3rem; font-weight:800; text-transform:uppercase; letter-spacing:1px; color:#fff; margin:0 0 4px; }
    .manual-card-header p { font-size:0.8rem; color:#c5a059; margin:0; letter-spacing:0.1em; text-transform:uppercase; }
    .manual-doc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:10px; }
    .manual-doc-item a { display:flex; align-items:center; gap:12px; text-decoration:none; color:rgba(255,255,255,0.8); font-size:0.85rem; padding:12px 16px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:10px; transition:all 0.25s; }
    .manual-doc-item a:hover { background:rgba(197,160,89,0.12); border-color:rgba(197,160,89,0.35); color:#fff; }

    /* FILE BADGES */
    .doc-ext { font-size:0.6rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; padding:2px 7px; border-radius:4px; flex-shrink:0; }
    .doc-ext.pdf  { background:rgba(220,53,69,0.2);  color:#ff7b86; }
    .doc-ext.docx,.doc-ext.doc { background:rgba(30,130,220,0.2); color:#7ec8ff; }
    .doc-ext.xlsx,.doc-ext.xls { background:rgba(40,167,69,0.2);  color:#7fffb0; }
    .doc-ext.ppt,.doc-ext.pptx { background:rgba(255,140,0,0.2);  color:#ffd080; }

    /* ── FULL-SCREEN MODAL ───────────────────────────────────────── */
    #sgi-modal {
      position:fixed; inset:0; z-index:9999;
      display:flex; align-items:stretch;
      opacity:0; pointer-events:none;
      transition:opacity 0.3s ease;
    }
    #sgi-modal.open { opacity:1; pointer-events:all; }

    .modal-backdrop {
      position:absolute; inset:0;
      background:rgba(0,5,20,0.8); backdrop-filter:blur(12px);
    }

    .modal-panel {
      position:relative; z-index:1;
      width:min(90vw,1120px); max-height:100vh;
      margin:0 auto; display:flex; flex-direction:column;
      background:linear-gradient(160deg,rgba(8,20,55,0.99),rgba(3,10,30,0.999));
      border-left:1px solid rgba(197,160,89,0.2);
      border-right:1px solid rgba(197,160,89,0.2);
      transform:translateY(60px) scale(0.97);
      transition:transform 0.4s cubic-bezier(0.34,1.3,0.64,1);
    }
    #sgi-modal.open .modal-panel { transform:translateY(0) scale(1); }

    /* Modal Header */
    .modal-header {
      display:flex; align-items:center; gap:18px; padding:28px 36px 20px;
      border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0;
      background:linear-gradient(to right,rgba(27,57,106,0.45),transparent);
    }
    .modal-head-icon {
      font-size:2rem; width:58px; height:58px; display:flex; align-items:center;
      justify-content:center; border-radius:16px; flex-shrink:0;
      background:rgba(197,160,89,0.14); border:1px solid rgba(197,160,89,0.35);
    }
    .modal-head-text { flex:1; min-width:0; }
    .modal-head-norm { font-size:0.62rem; font-weight:700; letter-spacing:0.22em; text-transform:uppercase; color:#c5a059; margin-bottom:4px; }
    .modal-head-title { font-size:clamp(0.95rem,2.2vw,1.35rem); font-weight:900; text-transform:uppercase; letter-spacing:1px; color:#fff; margin:0 0 4px; line-height:1.2; }
    .modal-head-count { font-size:0.78rem; color:rgba(255,255,255,0.4); }
    .modal-close-btn {
      width:42px; height:42px; border-radius:50%; flex-shrink:0;
      background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.12);
      color:rgba(255,255,255,0.65); font-size:1rem; cursor:pointer;
      display:flex; align-items:center; justify-content:center; transition:all 0.2s;
    }
    .modal-close-btn:hover { background:rgba(220,50,50,0.25); border-color:rgba(220,50,50,0.4); color:#fff; transform:rotate(90deg); }

    /* Modal inner search */
    .modal-search {
      display:flex; align-items:center; gap:10px; margin:18px 36px 0;
      padding:11px 20px; background:rgba(255,255,255,0.05);
      border:1px solid rgba(255,255,255,0.1); border-radius:40px; flex-shrink:0;
    }
    .modal-search:focus-within { border-color:rgba(197,160,89,0.45); }
    .modal-search input { background:none; border:none; outline:none; color:#fff; font-size:0.92rem; font-family:"Roboto",sans-serif; width:100%; }
    .modal-search input::placeholder { color:rgba(255,255,255,0.3); }

    /* Modal body */
    .modal-body { flex:1; overflow-y:auto; padding:22px 36px 48px; }
    .modal-body::-webkit-scrollbar { width:5px; }
    .modal-body::-webkit-scrollbar-thumb { background:rgba(197,160,89,0.35); border-radius:3px; }

    /* Document groups */
    .modal-group { margin-bottom:28px; }
    .modal-group-label {
      font-size:0.67rem; font-weight:700; letter-spacing:0.18em; text-transform:uppercase;
      color:#c5a059; padding:7px 14px; border-radius:8px;
      background:rgba(197,160,89,0.08); border-left:3px solid rgba(197,160,89,0.5);
      margin-bottom:12px; word-break:break-word;
    }
    .modal-file-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(310px,1fr)); gap:8px; }
    .modal-file-item { display:flex; /* show by default */ }
    .modal-file-item.hidden-doc { display:none; }
    .modal-group.all-hidden { display:none; }
    .modal-file-item a {
      display:flex; align-items:flex-start; gap:11px; text-decoration:none;
      color:rgba(255,255,255,0.75); font-size:0.83rem; padding:11px 14px;
      background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.07);
      border-radius:10px; transition:all 0.2s; line-height:1.45; width:100%;
    }
    .modal-file-item a:hover { background:rgba(197,160,89,0.1); border-color:rgba(197,160,89,0.3); color:#fff; transform:translateX(4px); }

    /* Empty */
    .modal-empty { text-align:center; padding:70px 20px; }
    .modal-empty p { color:rgba(255,255,255,0.3); font-size:0.9rem; margin-top:12px; }
    .soon-badge { display:inline-block; background:rgba(197,160,89,0.1); border:1px solid rgba(197,160,89,0.3); color:#c5a059; font-size:0.62rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; padding:5px 14px; border-radius:20px; }

    /* RESPONSIVE */
    @media (max-width:1024px) { .process-grid { grid-template-columns:repeat(2,1fr); } }
    @media (max-width:640px) {
      .hero { padding:130px 16px 50px; }
      .process-grid { grid-template-columns:1fr; }
      .manual-card { padding:28px 20px; }
      .manual-card::before { display:none; }
      .modal-header { padding:18px; }
      .modal-body { padding:16px 18px 40px; }
      .modal-search { margin:14px 18px 0; }
      .modal-file-grid { grid-template-columns:1fr; }
    }
  </style>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-badges">
      <span class="hero-badge">🏆 ISO 9001:2015</span>
      <span class="hero-badge">🌿 ISO 14001:2015</span>
      <span class="hero-badge">🔒 ISO 45001:2018</span>
      <span class="hero-badge">⚡ ISO 50001:2018</span>
    </div>
    <h1 class="hero-title">Sistema de <span>Gestión Integrado</span></h1>
    <div class="hero-divider"></div>
    <p class="hero-sub">Instituto Tecnológico de Pachuca · TecNM · Documentación y Procesos Estratégicos</p>
  </div>

  <div class="page-wrap">
    <!-- GLOBAL SEARCH -->
    <div class="search-wrap">
      <span>🔍</span>
      <input id="sgi-search" type="text" placeholder="Buscar entre todos los documentos del SGI..." autocomplete="off" />
    </div>

    <!-- MANUAL DEL SGI -->
    <div class="manual-card">
      <div class="manual-card-header">
        <div class="manual-card-icon">📖</div>
        <div>
          <h2>Manual del Sistema de Gestión Integrado</h2>
          <p>Documento maestro · {manualFiles.length} archivo(s)</p>
        </div>
      </div>
      <div class="manual-doc-grid">
        {manualGroups.flatMap(g => g.files).map((f) => (
          <div class="manual-doc-item">
            <a href={`${BASE_CLEAN}${f.url}`} target="_blank" rel="noopener">
              <span>{f.icon}</span>
              <span style="flex:1;word-break:break-word;">{f.name}</span>
              <span class={`doc-ext ${f.ext.toLowerCase()}`}>{f.ext}</span>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- PROCESOS ESTRATÉGICOS -->
    <h2 class="section-title">Procesos Estratégicos</h2>

    <div class="process-grid">
      {processes.map((proc) => (
        <button
          class={`proc-card ${proc.color}`}
          data-process-id={proc.id}
          aria-label={`Ver documentos: ${proc.title}`}
        >
          <div class="proc-inner">
            <div class="proc-icon">{proc.icon}</div>
            <div class="proc-meta">
              <div class="proc-norm">{proc.norm}</div>
              <div class="proc-title">{proc.title}</div>
              <div class={`proc-chip ${proc.files.length === 0 ? "empty" : ""}`}>
                {proc.files.length > 0 ? `📂 ${proc.files.length} documentos` : "⏳ Próximamente"}
              </div>
            </div>
            <span class="proc-arrow">›</span>
          </div>
        </button>
      ))}
    </div>
  </div>

  <!-- ── MODAL ───────────────────────────────────────────────────── -->
  <div id="sgi-modal" role="dialog" aria-modal="true" aria-labelledby="modal-head-title">
    <div class="modal-backdrop" id="modal-backdrop"></div>
    <div class="modal-panel">
      <div class="modal-header">
        <div class="modal-head-icon" id="modal-icon">📁</div>
        <div class="modal-head-text">
          <div class="modal-head-norm"  id="modal-norm">—</div>
          <div class="modal-head-title" id="modal-head-title">—</div>
          <div class="modal-head-count" id="modal-count">—</div>
        </div>
        <button class="modal-close-btn" id="modal-close" aria-label="Cerrar">✕</button>
      </div>
      <div class="modal-search">
        <span style="opacity:0.45">🔍</span>
        <input id="modal-search-input" type="text" placeholder="Buscar en este proceso..." autocomplete="off" />
      </div>
      <div class="modal-body" id="modal-body"></div>
    </div>
  </div>

  <!-- Process data for JS -->
  <script id="sgi-json" type="application/json" set:html={JSON.stringify(
    processes.map(p => ({
      id: p.id, icon: p.icon, title: p.title, norm: p.norm,
      groups: p.groups.map(g => ({
        groupName: g.groupName,
        files: g.files.map(f => ({ name: f.name, url: f.url, icon: f.icon, ext: f.ext }))
      }))
    }))
  )}>
  </script>

  <script define:vars={{ BASE_CLEAN }}>
    var DATA = JSON.parse(document.getElementById("sgi-json").textContent);
    var PM = {};
    DATA.forEach(function(p){ PM[p.id] = p; });

    var modal   = document.getElementById("sgi-modal");
    var backdrop= document.getElementById("modal-backdrop");
    var mClose  = document.getElementById("modal-close");
    var mIcon   = document.getElementById("modal-icon");
    var mNorm   = document.getElementById("modal-norm");
    var mTitle  = document.getElementById("modal-head-title");
    var mCount  = document.getElementById("modal-count");
    var mBody   = document.getElementById("modal-body");
    var mSearch = document.getElementById("modal-search-input");

    function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }

    function extCls(e){
      var v=e.toLowerCase();
      if(v==="pdf") return "pdf";
      if(v==="docx"||v==="doc") return "docx";
      if(v==="xlsx"||v==="xls") return "xlsx";
      if(v==="ppt"||v==="pptx") return "ppt";
      return "";
    }

    function openModal(id){
      var p = PM[id]; if(!p) return;
      mIcon.textContent  = p.icon;
      mNorm.textContent  = p.norm;
      mTitle.textContent = p.title;
      var total = p.groups.reduce(function(s,g){ return s+g.files.length; },0);
      mCount.textContent = total ? total+" documentos" : "Sin documentos";
      mSearch.value = "";

      if(!total){
        mBody.innerHTML = '<div class="modal-empty"><div style="font-size:3rem">⏳</div><div class="soon-badge">Próximamente</div><p>Los documentos de este proceso serán publicados próximamente.</p></div>';
      } else {
        var show = p.groups.length > 1;
        var html = "";
        p.groups.forEach(function(g){
          html += '<div class="modal-group">';
          if(show) html += '<div class="modal-group-label">'+esc(g.groupName)+'</div>';
          html += '<div class="modal-file-grid">';
          g.files.forEach(function(f){
            html += '<div class="modal-file-item" data-name="'+f.name.toLowerCase()+'">' +
              '<a href="'+BASE_CLEAN+f.url+'" target="_blank" rel="noopener">' +
                '<span style="flex-shrink:0">'+f.icon+'</span>' +
                '<span style="flex:1;word-break:break-word">'+esc(f.name)+'</span>' +
                '<span class="doc-ext '+extCls(f.ext)+'">'+esc(f.ext)+'</span>' +
              '</a></div>';
          });
          html += '</div></div>';
        });
        mBody.innerHTML = html;
      }

      modal.classList.add("open");
      document.body.style.overflow="hidden";
      setTimeout(function(){ mSearch.focus(); },380);
    }

    function closeModal(){
      modal.classList.remove("open");
      document.body.style.overflow="";
    }

    // Wire cards
    document.querySelectorAll(".proc-card[data-process-id]").forEach(function(btn){
      btn.addEventListener("click",  function(){ openModal(btn.getAttribute("data-process-id")); });
      btn.addEventListener("keydown", function(e){ if(e.key==="Enter"||e.key===" "){ e.preventDefault(); btn.click(); } });
    });

    mClose.addEventListener("click", closeModal);
    backdrop.addEventListener("click", closeModal);
    document.addEventListener("keydown", function(e){ if(e.key==="Escape") closeModal(); });

    // Modal search
    mSearch.addEventListener("input", function(){
      var q = mSearch.value.toLowerCase().trim();
      mBody.querySelectorAll(".modal-file-item").forEach(function(el){
        var n = el.getAttribute("data-name")||"";
        el.classList.toggle("hidden-doc", q.length>0 && !n.includes(q));
      });
      mBody.querySelectorAll(".modal-group").forEach(function(g){
        var vis = g.querySelectorAll(".modal-file-item:not(.hidden-doc)").length;
        g.classList.toggle("all-hidden", q.length>0 && vis===0);
      });
    });

    // Global page search → open matching process modal
    var gSearch = document.getElementById("sgi-search");
    if(gSearch){
      gSearch.addEventListener("input", function(){
        var q = gSearch.value.toLowerCase().trim();
        if(q.length < 2) return;
        for(var i=0;i<DATA.length;i++){
          var proc = DATA[i];
          for(var j=0;j<proc.groups.length;j++){
            for(var k=0;k<proc.groups[j].files.length;k++){
              if(proc.groups[j].files[k].name.toLowerCase().includes(q)){
                openModal(proc.id);
                setTimeout(function(){ mSearch.value=q; mSearch.dispatchEvent(new Event("input")); },60);
                return;
              }
            }
          }
        }
      });
    }
  </script>
</Layout>
