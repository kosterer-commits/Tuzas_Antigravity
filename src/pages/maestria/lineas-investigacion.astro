---
import Layout from "../../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
---

<Layout title="Líneas de Investigación - Maestría en Ingeniería Mecánica">
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
        }
        .hero {
            text-align: center;
            padding: 160px 20px 60px;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(197, 160, 89, 0.15);
            border: 1px solid rgba(197, 160, 89, 0.4);
            color: #c5a059;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 8px 20px;
            border-radius: 50px;
            margin-bottom: 24px;
            backdrop-filter: blur(8px);
        }
        .hero-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 3px;
            line-height: 1.1;
            margin: 0 auto 16px;
            max-width: 900px;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }
        .hero-title span {
            color: #c5a059;
        }
        .hero-divider {
            width: 80px;
            height: 4px;
            background: linear-gradient(
                to right,
                transparent,
                #c5a059,
                transparent
            );
            margin: 0 auto 20px;
            border-radius: 4px;
        }
        .hero-sub {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1.1rem;
            letter-spacing: 0.05em;
            margin: 0;
        }
        .page-wrap {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 24px 80px;
        }
        .section-title {
            text-align: center;
            color: #fff;
            font-size: clamp(1.4rem, 2.5vw, 2rem);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0 0 40px;
        }
        .section-title::after {
            content: "";
            display: block;
            width: 50px;
            height: 3px;
            background: #c5a059;
            margin: 12px auto 0;
            border-radius: 2px;
        }
        .lgac-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px;
            margin-bottom: 60px;
        }
        .lgac-card {
            background: rgba(10, 20, 50, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.2);
            border-radius: 24px;
            padding: 44px 40px;
            position: relative;
            overflow: hidden;
            transition: all 0.35s ease;
        }
        .lgac-card:hover {
            border-color: rgba(197, 160, 89, 0.5);
            transform: translateY(-5px);
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
        }
        .lgac-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            border-radius: 24px 0 0 24px;
        }
        .lgac-card.tma::before {
            background: linear-gradient(to bottom, #c5a059, #7ea8d8);
        }
        .lgac-card.adtsm::before {
            background: linear-gradient(to bottom, #1b396a, #c5a059);
        }
        .lgac-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.65rem;
            font-weight: 800;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 6px 14px;
            border-radius: 50px;
            margin-bottom: 16px;
        }
        .lgac-card.tma .lgac-badge {
            background: rgba(197, 160, 89, 0.2);
            border: 1px solid rgba(197, 160, 89, 0.4);
            color: #c5a059;
        }
        .lgac-card.adtsm .lgac-badge {
            background: rgba(27, 57, 106, 0.4);
            border: 1px solid rgba(27, 57, 106, 0.7);
            color: #7ea8d8;
        }
        .lgac-card h2 {
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            margin: 0 0 12px;
            line-height: 1.3;
        }
        .lgac-card h3 {
            font-size: 1rem;
            font-weight: 400;
            color: rgba(255, 255, 255, 0.55);
            margin: 0 0 24px;
            font-style: italic;
        }
        .lgac-desc {
            color: rgba(255, 255, 255, 0.85);
            font-size: 0.95rem;
            line-height: 1.8;
            margin: 0 0 24px;
        }
        .topics-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .topics-list li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            line-height: 1.5;
        }
        .topics-list li::before {
            content: "›";
            color: #c5a059;
            font-size: 1.2rem;
            font-weight: 700;
            flex-shrink: 0;
            line-height: 1.3;
        }
        @media (max-width: 768px) {
            .lgac-grid {
                grid-template-columns: 1fr;
            }
            .hero {
                padding: 140px 20px 40px;
            }
        }
    </style>

    <div class="hero">
        <div class="hero-badge">
            <i class="fa-solid fa-flask"></i> Investigación · Posgrado
        </div>
        <h1 class="hero-title">Líneas de <span>Investigación</span></h1>
        <div class="hero-divider"></div>
        <p class="hero-sub">
            Generación y Aplicación del Conocimiento · Maestría en Ingeniería
            Mecánica
        </p>
    </div>

    <div class="page-wrap">
        <h2 class="section-title">Nuestras LGAC</h2>
        <div class="lgac-grid">
            <div class="lgac-card tma">
                <div class="lgac-badge">
                    <i class="fa-solid fa-fire"></i> LGAC 1
                </div>
                <h2>Termofluidos y Materiales Avanzados</h2>
                <h3>TMA</h3>
                <p class="lgac-desc">
                    Esta línea integra el estudio de fenómenos termodinámicos,
                    de transferencia de calor y dinámica de fluidos con el
                    desarrollo y caracterización de materiales de alto desempeño
                    para aplicaciones industriales y energéticas.
                </p>
                <ul class="topics-list">
                    <li>Dinámica de Fluidos Computacional (CFD)</li>
                    <li>Transferencia de calor y diseño de intercambiadores</li>
                    <li>Tribología y desgaste de materiales</li>
                    <li>
                        Caracterización de materiales compuestos y
                        superaleaciones
                    </li>
                    <li>
                        Energías alternativas y sistemas de ahorro energético
                    </li>
                    <li>Turbomaquinaria y flujo compresible</li>
                </ul>
            </div>

            <div class="lgac-card adtsm">
                <div class="lgac-badge">
                    <i class="fa-solid fa-gears"></i> LGAC 2
                </div>
                <h2>Análisis, Diseño y Tecnología de Sistemas Mecánicos</h2>
                <h3>ADTSM</h3>
                <p class="lgac-desc">
                    Enfocada al análisis y diseño de sistemas mecánicos,
                    automatización y robótica, esta línea abarca desde la
                    modelación mecánica hasta la implementación de tecnologías
                    de manufactura avanzada y mecatrónica.
                </p>
                <ul class="topics-list">
                    <li>
                        Diseño y modelado de maquinaria agrícola e industrial
                    </li>
                    <li>Automatización, robótica y mecatrónica</li>
                    <li>Análisis de sistemas dinámicos y vibraciones</li>
                    <li>Manufactura avanzada y procesos de fabricación</li>
                    <li>Simulación y elementos finitos (FEM)</li>
                    <li>Domótica y sistemas embebidos</li>
                </ul>
            </div>
        </div>

        <!-- Investigadores por LGAC -->
        <h2 class="section-title">Investigadores por Línea</h2>
        <div
            style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:60px;"
        >
            <div
                style="background:rgba(10,20,50,0.82);backdrop-filter:blur(20px);border:1px solid rgba(197,160,89,0.2);border-radius:20px;padding:32px 36px;"
            >
                <div
                    style="font-size:0.65rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c5a059;margin-bottom:16px;"
                >
                    TMA — Termofluidos y Materiales Avanzados
                </div>
                <div style="display:flex;flex-direction:column;gap:12px;">
                    {
                        [
                            [
                                "Dra. Marisa Moreno Ríos",
                                "SNI Nivel 1",
                                "marisa-moreno",
                            ],
                            [
                                "Dr. Edgar Vera Cárdenas",
                                "SNI Nivel 1",
                                "edgar-vera",
                            ],
                            [
                                "Dra. Erika Osiris Ávila Dávila",
                                "SNI Nivel 1",
                                "erika-avila",
                            ],
                            [
                                "Dr. Armando Irvin Martínez Pérez",
                                "SNI Nivel 1",
                                "armando-martinez",
                            ],
                            [
                                "Dr. Celerino Reséndiz Rosas",
                                "Docente Especialista",
                                "celerino-resendiz",
                            ],
                            [
                                "Dr. Abdiel Gómez Mercado",
                                "Docente Especialista",
                                "abdiel-gomez",
                            ],
                        ].map(([name, dist, slug]) => (
                            <a
                                href={`${BASE}maestria/profesores/${slug}`}
                                style="display:flex;justify-content:space-between;align-items:center;gap:12px;text-decoration:none;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);transition:all 0.3s ease;"
                                class="prof-link"
                            >
                                <span style="color:#fff;font-weight:600;font-size:0.9rem;">
                                    {name}
                                </span>
                                <span style="color:#c5a059;font-size:0.75rem;white-space:nowrap;">
                                    {dist}
                                </span>
                            </a>
                        ))
                    }
                </div>
            </div>

            <div
                style="background:rgba(10,20,50,0.82);backdrop-filter:blur(20px);border:1px solid rgba(27,57,106,0.4);border-radius:20px;padding:32px 36px;"
            >
                <div
                    style="font-size:0.65rem;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#7ea8d8;margin-bottom:16px;"
                >
                    ADTSM — Análisis, Diseño y Tecnología de Sistemas Mecánicos
                </div>
                <div style="display:flex;flex-direction:column;gap:12px;">
                    {
                        [
                            [
                                "Dr. Luis Manuel Palacios Pineda",
                                "SNI Nivel 1",
                                "luis-palacios",
                            ],
                            [
                                "Dr. Hugo Francisco Abundis Fong",
                                "SNI Nivel 1",
                                "hugo-abundis",
                            ],
                            [
                                "Dr. Ignacio Ramírez Vargas",
                                "Perfil Deseable",
                                "ignacio-ramirez",
                            ],
                            [
                                "Dr. Mario Emigdio Rodríguez Castillo",
                                "Perfil Deseable",
                                "mario-rodriguez",
                            ],
                        ].map(([name, dist, slug]) => (
                            <a
                                href={`${BASE}maestria/profesores/${slug}`}
                                style="display:flex;justify-content:space-between;align-items:center;gap:12px;text-decoration:none;padding:10px 14px;border-radius:10px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);transition:all 0.3s ease;"
                            >
                                <span style="color:#fff;font-weight:600;font-size:0.9rem;">
                                    {name}
                                </span>
                                <span style="color:#7ea8d8;font-size:0.75rem;white-space:nowrap;">
                                    {dist}
                                </span>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</Layout>
