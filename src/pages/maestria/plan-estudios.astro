---
import Layout from "../../layouts/Layout.astro";
const BASE = import.meta.env.BASE_URL;
---

<Layout title="Plan de Estudios - Maestría en Ingeniería Mecánica">
    <style>
        * {
            box-sizing: border-box;
        }
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            background-image:
                linear-gradient(
                    to top,
                    rgba(0, 0, 0, 0.6),
                    rgba(0, 0, 0, 0.15),
                    transparent
                ),
                url("/images/Fondos/DEPI.jpeg");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            overflow-x: hidden;
            font-family: "Roboto", sans-serif;
        }
        .hero {
            text-align: center;
            padding: 160px 20px 60px;
        }
        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(197, 160, 89, 0.15);
            border: 1px solid rgba(197, 160, 89, 0.4);
            color: #c5a059;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            padding: 8px 20px;
            border-radius: 50px;
            margin-bottom: 24px;
            backdrop-filter: blur(8px);
        }
        .hero-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 900;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 3px;
            line-height: 1.1;
            margin: 0 auto 16px;
            max-width: 900px;
            text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }
        .hero-title span {
            color: #c5a059;
        }
        .hero-divider {
            width: 80px;
            height: 4px;
            background: linear-gradient(
                to right,
                transparent,
                #c5a059,
                transparent
            );
            margin: 0 auto 20px;
            border-radius: 4px;
        }
        .hero-sub {
            color: rgba(255, 255, 255, 0.75);
            font-size: 1.1rem;
            margin: 0;
        }
        .page-wrap {
            max-width: 1100px;
            margin: 0 auto;
            padding: 0 24px 80px;
        }
        .info-card {
            background: rgba(10, 20, 50, 0.85);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(197, 160, 89, 0.2);
            border-radius: 24px;
            padding: 48px 56px;
            margin-bottom: 40px;
            position: relative;
            overflow: hidden;
        }
        .info-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(to bottom, #c5a059, #1b396a);
            border-radius: 24px 0 0 24px;
        }
        .info-card p {
            color: rgba(255, 255, 255, 0.88);
            font-size: 1.05rem;
            line-height: 1.85;
            margin: 0 0 16px;
        }
        .info-card p:last-child {
            margin-bottom: 0;
        }
        .info-card strong {
            color: #c5a059;
        }
        .section-title {
            text-align: center;
            color: #fff;
            font-size: clamp(1.4rem, 2.5vw, 2rem);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin: 0 0 40px;
        }
        .section-title::after {
            content: "";
            display: block;
            width: 50px;
            height: 3px;
            background: #c5a059;
            margin: 12px auto 0;
            border-radius: 2px;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: rgba(10, 20, 50, 0.82);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            padding: 28px;
            text-align: center;
            transition: all 0.3s ease;
        }
        .stat-card:hover {
            border-color: rgba(197, 160, 89, 0.4);
            transform: translateY(-4px);
        }
        .stat-number {
            font-size: 2.8rem;
            font-weight: 900;
            color: #c5a059;
            display: block;
            line-height: 1;
        }
        .stat-label {
            font-size: 0.85rem;
            color: rgba(255, 255, 255, 0.65);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-top: 8px;
        }
        .image-card {
            background: rgba(10, 20, 50, 0.82);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            margin-bottom: 32px;
            overflow: hidden;
        }
        .image-card h3 {
            font-size: 1.2rem;
            font-weight: 800;
            color: #c5a059;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 0 0 28px;
            text-align: center;
        }
        .image-card img {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
            display: block;
            margin: 0 auto;
            transition: transform 0.3s ease;
        }
        .image-card img:hover {
            transform: scale(1.02);
        }
        @media (max-width: 768px) {
            .hero {
                padding: 140px 20px 40px;
            }
            .info-card {
                padding: 32px 24px;
            }
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="hero">
        <div class="hero-badge">
            <i class="fa-solid fa-book-open"></i> Estructura Académica
        </div>
        <h1 class="hero-title">Plan de <span>Estudios</span></h1>
        <div class="hero-divider"></div>
        <p class="hero-sub">Maestría en Ingeniería Mecánica · TecNM Pachuca</p>
    </div>

    <div class="page-wrap">
        <!-- Descripción -->
        <div class="info-card">
            <p>
                De acuerdo al Documento Normativo de Posgrado de la DGEST, el
                periodo para que el estudiante cubra la estructura académica,
                desarrolle y apruebe la tesis correspondiente será de <strong
                    >dos años</strong
                >, contados a partir de la fecha en que inicie sus estudios.
            </p>
            <p>
                El programa está estructurado en <strong>4 semestres</strong> con
                un total de <strong>75 créditos</strong>, combinando asignaturas
                teóricas avanzadas, seminarios de investigación y el desarrollo
                de tesis.
            </p>
        </div>

        <!-- Stats -->
        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-number">4</span>
                <div class="stat-label">Semestres</div>
            </div>
            <div class="stat-card">
                <span class="stat-number">75</span>
                <div class="stat-label">Créditos totales</div>
            </div>
            <div class="stat-card">
                <span class="stat-number">2</span>
                <div class="stat-label">Años de duración</div>
            </div>
        </div>

        <!-- Imagen Plan -->
        <h2 class="section-title">Estructura del Programa</h2>
        <div class="image-card">
            <h3>
                <i class="fa-solid fa-diagram-project"></i>&nbsp; Mapa
                Curricular
            </h3>
            <img
                src={`${BASE}images/plan_estudios_posgrado/Imagen1.png`}
                alt="Plan de Estudios - Estructura Académica"
            />
        </div>

        <div class="image-card">
            <h3>
                <i class="fa-solid fa-table-list"></i>&nbsp; Materias Optativas
            </h3>
            <img
                src={`${BASE}images/plan_estudios_posgrado/tablas_plan_estudio.png`}
                alt="Tablas de Materias Optativas"
            />
        </div>
    </div>
</Layout>
