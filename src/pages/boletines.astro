---

<Layout title="Boletines Electrónicos — ITP">
    <section class="hero-section">
        <div class="hero-bg"></div>
        <div class="hero-content">
            <div class="hero-chip">
                <span class="chip-dot"></span>
                Publicaciones Oficiales
            </div>
            <h1 class="hero-title">
                Boletines <span class="hero-accent">Electrónicos</span>
            </h1>
            <p class="hero-desc">
                Consulta los comunicados oficiales, eventos y noticias destacadas del Instituto Tecnológico de Pachuca.
            </p>
        </div>
    </section>

    <!-- Barra de Búsqueda -->
    <section class="search-section">
        <div class="search-container">
            <div class="search-wrapper">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="searchInput" placeholder="Buscar boletín por título o número..." />
            </div>
        </div>
    </section>

    <!-- Grid de Boletines -->
    <section class="boletines-section">
        <div class="boletines-container">
            <div class="boletines-grid" id="boletines-grid">
                {
                    BOLETINES_REVERSED.map((boletin) => (
                        <a href={`${BASE}archives/bol/${boletin.file}`} target="_blank" class="boletin-card" data-title={boletin.title.toLowerCase()}>
                            <div class="card-icon">
                                📄
                            </div>
                            <div class="card-content">
                                <h3 class="card-title">{boletin.title}</h3>
                                <span class="card-action">Ver Documento &rarr;</span>
                            </div>
                        </a>
                    ))
                }
            </div>
            
            <div id="no-results" class="no-results" style="display: none;">
                <span class="no-results-icon">🔍</span>
                <h3>No se encontraron resultados</h3>
                <p>Intenta usar otras palabras clave en tu búsqueda.</p>
            </div>
        </div>
    </section>
</Layout>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const searchInput = document.getElementById("searchInput");
        const grid = document.getElementById("boletines-grid");
        const cards = grid ? Array.from(grid.querySelectorAll(".boletin-card")) : [];
        const noResults = document.getElementById("no-results");

        if (searchInput && cards && noResults) {
            searchInput.addEventListener("input", (e) => {
                const target = e.target;
                if (!target) return;
                const term = target.value.toLowerCase().trim();
                let visibleCount = 0;

                cards.forEach((card) => {
                    const el = card;
                    const title = el.dataset.title || "";
                    if (title.includes(term)) {
                        el.style.display = "flex";
                        visibleCount++;
                    } else {
                        el.style.display = "none";
                    }
                });

                if (visibleCount === 0) {
                    noResults.style.display = "flex";
                } else {
                    noResults.style.display = "none";
                }
            });
        }
    });
</script>

<style>
    /* ══ HERO (Shared Aesthetic) ══ */
    .hero-section {
        position: relative;
        min-height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 6.5rem 1.5rem 3rem;
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(
                ellipse at 50% 10%,
                rgba(27, 57, 106, 0.4) 0%,
                transparent 70%
            ),
            linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    }

    .hero-content {
        position: relative;
        text-align: center;
        max-width: 800px;
        z-index: 10;
    }

    .hero-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #e2e8f0;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.4rem 1rem;
        border-radius: 999px;
        margin-bottom: 1.5rem;
        font-family: "Inter", sans-serif;
    }

    .chip-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #38bdf8;
        animation: pulse-dot 2s infinite;
    }

    @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero-title {
        font-family: "Inter", sans-serif;
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 900;
        color: #ffffff;
        line-height: 1.1;
        margin: 0 0 1rem;
    }

    .hero-accent {
        background: linear-gradient(135deg, #38bdf8, #818cf8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-desc {
        font-family: "Inter", sans-serif;
        font-size: 1.05rem;
        color: #94a3b8;
        line-height: 1.6;
        margin: 0 auto;
        max-width: 650px;
    }

    /* ══ SEARCH ══ */
    .search-section {
        background: #1e293b;
        padding: 0 1.5rem 2rem;
    }
    .search-container {
