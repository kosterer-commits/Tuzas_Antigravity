---

<section
    class="pt-8 pb-2 overflow-hidden relative group"
    id="banner-carousel-section"
>
    <!-- Section Header -->
    <div
        class="mb-1 px-6 max-w-[1920px] mx-auto reveal-on-scroll flex flex-col items-center text-center relative"
    >
        <div class="mb-0">
             <div class="flex items-center justify-center gap-3 mb-1">
                <div class="w-12 h-1 bg-blue-500 rounded-full"></div>
                <span class="text-blue-400 font-bold tracking-[0.2em] uppercase text-sm">Comunicados</span>
                <div class="w-12 h-1 bg-blue-500 rounded-full"></div>
            </div>
            <h3 class="text-3xl sm:text-4xl md:text-6xl font-black text-white uppercase tracking-tight">
                Avisos y <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">Eventos</span>
            </h3>
        </div>


    </div>

    <!-- Carousel Container -->
    <div
        class="relative w-full overflow-x-auto scrollbar-hide perspective-1000"
        id="carousel-container"
    >
        <div class="flex gap-4 px-4 w-max items-center pt-1 pb-2" id="track">
            {
                infiniteBanners.map((banner, index) => (
                    <a
                        href={banner.link}
                        class="carousel-card group/card relative w-[85vw] md:w-[950px] lg:w-[1400px] max-h-[65vh] rounded-3xl overflow-hidden flex-shrink-0 select-none shadow-2xl shadow-black/80 transition-all duration-700 ease-out transform origin-center"
                        data-index={index}
                        data-real-index={(index % banners.length) + 1}
                    >
                        <!-- Image -->
                        <img
                            src={banner.image}
                            alt={banner.title}
                            draggable="false"
                            data-banner-img
                            class="w-full h-full object-contain bg-black transition-transform duration-1000 group-hover/card:scale-105 pointer-events-none filter brightness-75 group-hover/card:brightness-100"
                        />
                        
                        <!-- Cinematic Gradient Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 transition-opacity duration-300" />

                        <!-- Floating Number Badge -->
                        <div
                            class="badge-num absolute top-4 right-4 w-10 h-10 rounded-full bg-black/70 backdrop-blur-md border border-white/20 flex items-center justify-center text-white font-extrabold text-sm shadow-lg opacity-0 scale-75 transition-all duration-300 pointer-events-none z-30"
                            aria-hidden="true"
                        >
                            {(index % banners.length) + 1}
                        </div>

                        <!-- Content Box - Minimalist & Large -->
                        <div class="absolute bottom-0 left-0 w-full p-4 sm:p-8 md:p-12 flex flex-col justify-end h-full">
                            <div class="transform translate-y-4 group-hover/card:translate-y-0 transition-transform duration-500">
                                <span class={`inline-block px-3 py-1 mb-4 text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] border ${banner.color} rounded-full bg-black/50 backdrop-blur-md`}>
                                    {banner.category}
                                </span>
                                <h3 class="text-xl sm:text-2xl md:text-4xl lg:text-5xl font-bold text-white leading-tight mb-3 sm:mb-4 drop-shadow-lg max-w-3xl">
                                    {banner.title}
                                </h3>
                                <div class="h-1 w-24 bg-blue-500 rounded-full mb-6 opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 delay-100"></div>
                                <div class="flex items-center gap-3 text-sm md:text-base font-bold text-gray-300 group-hover/card:text-white transition-colors opacity-0 group-hover/card:opacity-100 duration-300 delay-200">
                                    <span>Leer Comunicado</span>
                                    <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center border border-white/20 group-hover/card:bg-white group-hover/card:text-black transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                ))
            }
        </div>
    </div>

    <!-- Desktop Scrubber Bar (hidden on mobile/tablet) -->
    <div class="hidden lg:block pb-6 pt-2" id="scrubber-wrapper">
        <div class="scrubber-pill max-w-4xl mx-auto">
            <!-- Left arrow btn -->
            <button id="scrubber-prev" class="scrubber-arrow" aria-label="Anterior" title="Anterior">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>

            <!-- Track area -->
            <div class="scrubber-track-wrap">
                <input
                    type="range"
                    id="carousel-scrubber"
                    min="0"
                    max="1000"
                    value="500"
                    class="carousel-scrubber"
                    aria-label="Navegar banners"
                />
            </div>

            <!-- Right arrow btn -->
            <button id="scrubber-next" class="scrubber-arrow" aria-label="Siguiente" title="Siguiente">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>

            <!-- Counter badge -->
            <div class="scrubber-counter-badge">
                <span id="scrubber-counter" class="counter-num">1</span>
                <span class="counter-sep">/</span>
                <span class="counter-total">{banners.length}</span>
            </div>
        </div>
    </div>
</section>

<style>
    .perspective-1000 {
        perspective: 1500px;
    }
    
    /* Active/Center card scaling */
    .carousel-card.active {
        transform: scale(1);
        z-index: 20;
        filter: brightness(100%);
        box-shadow: 0 40px 80px -12px rgba(0, 0, 0, 0.9);
        opacity: 1;
    }

    .carousel-card:not(.active) {
        transform: scale(0.85);
        opacity: 0.5;
        z-index: 10;
        filter: blur(2px) grayscale(100%) brightness(50%);
    }

    /* ══ PREMIUM SCRUBBER ══ */
    .scrubber-pill {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 1rem 0.6rem 0.75rem;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 9999px;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow:
            0 4px 24px rgba(0, 0, 0, 0.4),
            0 1px 0 rgba(255,255,255,0.06) inset;
        transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }
    .scrubber-pill:focus-within,
    .scrubber-pill:hover {
        border-color: rgba(59, 130, 246, 0.45);
        box-shadow:
            0 4px 32px rgba(0, 0, 0, 0.5),
            0 0 0 1px rgba(59,130,246,0.2),
            0 1px 0 rgba(255,255,255,0.08) inset;
    }

    /* Arrow buttons */
    .scrubber-arrow {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.15);
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.6);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        padding: 0;
    }
    .scrubber-arrow:hover {
        background: rgba(59,130,246,0.25);
        border-color: rgba(59,130,246,0.5);
        color: #fff;
        transform: scale(1.08);
    }
    .scrubber-arrow:active {
        transform: scale(0.95);
        background: rgba(59,130,246,0.4);
    }

    /* Track wrapper */
    .scrubber-track-wrap {
        flex: 1;
        position: relative;
        display: flex;
        align-items: center;
        height: 36px;
    }

    /* Animated shimmer on the filled part */
    @keyframes scrubber-shimmer {
        0%   { background-position: -200% center; }
        100% { background-position: 200% center; }
    }

    /* Range input */
    .carousel-scrubber {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 10px;
        border-radius: 9999px;
        background:
            linear-gradient(
                to right,
                transparent var(--progress, 50%),
                rgba(255,255,255,0.10) var(--progress, 50%)
            );
        position: relative;
        outline: none;
        cursor: pointer;
        transition: height 0.2s ease;
    }
    /* Filled portion: gradient + animated shimmer overlay */
    .scrubber-track-wrap::before {
        content: '';
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: var(--progress, 50%);
        height: 10px;
        border-radius: 9999px;
        background:
            linear-gradient(90deg,
                rgba(255,255,255,0.18) 0%,
                rgba(255,255,255,0) 50%,
                rgba(255,255,255,0.12) 100%
            ),
            linear-gradient(90deg, #002147, #003d82, #0059b3, #003d82);
        background-size: 300% 100%, 100% 100%;
        animation: scrubber-shimmer 3s linear infinite;
        pointer-events: none;
        z-index: 1;
        transition: width 0.05s linear;
    }
    .carousel-scrubber:hover {
        height: 14px;
    }
    .carousel-scrubber:hover ~ .scrubber-track-wrap::before,
    .scrubber-track-wrap:hover::before {
        height: 14px;
    }

    /* Webkit thumb */
    .carousel-scrubber::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #ffffff, #dbeafe);
        border: none;
        box-shadow:
            0 0 0 3px rgba(59,130,246,0.5),
            0 4px 16px rgba(0,0,0,0.6),
            0 0 0 6px rgba(59,130,246,0.15);
        cursor: grab;
        position: relative;
        z-index: 2;
        transition: transform 0.15s ease, box-shadow 0.2s ease;
    }
    .carousel-scrubber::-webkit-slider-thumb:hover {
        transform: scale(1.15);
        box-shadow:
            0 0 0 3px #3b82f6,
            0 4px 20px rgba(0,0,0,0.7),
            0 0 0 10px rgba(59,130,246,0.2);
    }
    .carousel-scrubber:active::-webkit-slider-thumb {
        cursor: grabbing;
        transform: scale(1.2);
        background: radial-gradient(circle at 35% 35%, #dbeafe, #93c5fd);
        box-shadow:
            0 0 0 3px #60a5fa,
            0 4px 24px rgba(0,0,0,0.8),
            0 0 0 14px rgba(59,130,246,0.25);
    }

    /* Firefox thumb */
    .carousel-scrubber::-moz-range-thumb {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: radial-gradient(circle at 35% 35%, #ffffff, #dbeafe);
        border: none;
        box-shadow:
            0 0 0 3px rgba(59,130,246,0.5),
            0 4px 16px rgba(0,0,0,0.6);
        cursor: grab;
    }
    .carousel-scrubber::-moz-range-track {
        height: 10px;
        border-radius: 9999px;
        background: rgba(255,255,255,0.10);
    }

    /* Counter badge */
    .scrubber-counter-badge {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        gap: 3px;
        background: rgba(59,130,246,0.15);
        border: 1px solid rgba(59,130,246,0.3);
        border-radius: 9999px;
        padding: 0.25rem 0.7rem;
        font-family: "Inter", sans-serif;
        font-size: 0.78rem;
        font-weight: 700;
        color: #93c5fd;
        white-space: nowrap;
        min-width: 68px;
        justify-content: center;
        letter-spacing: 0.02em;
    }
    .counter-num {
        color: #fff;
        font-size: 0.9rem;
        font-weight: 800;
        min-width: 1.4ch;
        text-align: right;
        display: inline-block;
        transition: transform 0.15s ease;
    }
    .counter-sep {
        color: rgba(255,255,255,0.35);
        margin: 0 1px;
    }
    .counter-total {
        color: rgba(255,255,255,0.5);
    }

    /* Floating number badge show/hide */
    .badges-visible .badge-num {
        opacity: 1 !important;
        transform: scale(1) !important;
    }
    /* Highlight the center (active) card badge */
    .carousel-card.active .badge-num {
        background: rgba(59,130,246,0.85) !important;
        border-color: #3b82f6 !important;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.35);
    }
</style>

<script>
    function fitImagesToContainers() {
        const imgs = document.querySelectorAll<HTMLImageElement>('[data-banner-img]');
        imgs.forEach((img) => {
            const applyRatio = () => {
                const card = img.closest('.carousel-card') as HTMLElement | null;
                if (!card) return;
                const { naturalWidth, naturalHeight } = img;
                if (naturalWidth && naturalHeight) {
                    card.style.aspectRatio = `${naturalWidth} / ${naturalHeight}`;
                }
            };
            if (img.complete && img.naturalWidth) {
                applyRatio();
            } else {
                img.addEventListener('load', applyRatio, { once: true });
            }
        });
    }
    fitImagesToContainers();

    const totalBanners = document.querySelectorAll('.carousel-card[data-real-index]').length / 3; // divided by 3 (tripled)
    const counterEl = document.getElementById('scrubber-counter') as HTMLElement | null;

    const track = document.getElementById("track");
    const container = document.getElementById("carousel-container");
    const cards = document.querySelectorAll('.carousel-card');

    if (!track || !container) {
        console.error("Banner carousel elements not found");
    }

    let isDown = false;
    let startX = 0;
    let scrollLeft = 0;
    let autoScrollSpeed = 0.2; // Reduced speed
    let animationId: number;
    let isPaused = false;
    let velX = 0;
    let lastTime = Date.now();
    let scrubberDragging = false;
    let badgeHideTimer: ReturnType<typeof setTimeout> | null = null;

    // Show/hide floating number badges
    function showBadges() {
        if (badgeHideTimer) { clearTimeout(badgeHideTimer); badgeHideTimer = null; }
        track?.classList.add('badges-visible');
    }
    function hideBadgesDelayed(ms = 1200) {
        if (badgeHideTimer) clearTimeout(badgeHideTimer);
        badgeHideTimer = setTimeout(() => track?.classList.remove('badges-visible'), ms);
    }

    // Update the scrubber counter with the current center banner number
    function updateCounter() {
        if (!counterEl || !container || !track) return;
        const containerCenter = container.scrollLeft + container.clientWidth / 2;
        let closest: HTMLElement | null = null;
        let closestDist = Infinity;
        document.querySelectorAll<HTMLElement>('.carousel-card').forEach(card => {
            const dist = Math.abs(card.offsetLeft + card.clientWidth / 2 - containerCenter);
            if (dist < closestDist) { closestDist = dist; closest = card; }
        });
        if (closest) {
            const realIdx = parseInt((closest as HTMLElement).dataset.realIndex ?? '1', 10);
            counterEl.textContent = String(realIdx);
        }
    }

    const scrubber = document.getElementById('carousel-scrubber') as HTMLInputElement | null;

    // Detect touch/pointer device for scrubber visibility
    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    const trackWrap = document.querySelector('.scrubber-track-wrap') as HTMLElement | null;

    // Update scrubber fill gradient
    function updateScrubberFill() {
        if (!scrubber) return;
        const val = parseFloat(scrubber.value);
        const min = parseFloat(scrubber.min);
        const max = parseFloat(scrubber.max);
        const pct = ((val - min) / (max - min)) * 100;
        scrubber.style.setProperty('--progress', `${pct}%`);
        // Also push to the wrapper so ::before shimmer tracks it
        trackWrap?.style.setProperty('--progress', `${pct}%`);
    }

    // Sync scrubber → carousel
    function scrubberToScroll(value: number) {
        if (!container || !track) return;
        const third = track.scrollWidth / 3;
        // Map scrubber 0–1000 onto one-third of the track width
        const target = (value / 1000) * third;
        container.scrollLeft = third + target - (container.clientWidth / 2);
    }

    // Sync carousel → scrubber
    function scrollToScrubber() {
        if (!scrubber || !track || !container) return;
        const third = track.scrollWidth / 3;
        // Normalize current scroll within one loop (third)
        const rel = ((container.scrollLeft % third) + third) % third;
        const pct = rel / third;
        const newVal = Math.round(pct * 1000);
        scrubber.value = String(newVal);
        updateScrubberFill();
    }

    // Function to update card scaling based on position
    function updateCardScales() {
        if (!container || !cards.length) return;
        const containerCenter = container.scrollLeft + (container.clientWidth / 2);
        cards.forEach(card => {
            const cardElement = card as HTMLElement;
            const cardCenter = cardElement.offsetLeft + (cardElement.clientWidth / 2);
            const dist = Math.abs(containerCenter - cardCenter);
            if (dist < cardElement.clientWidth / 2) {
                cardElement.classList.add('active');
            } else {
                cardElement.classList.remove('active');
            }
        });
    }

    function animate() {
        if (!track || !container) return;

        const now = Date.now();
        lastTime = now;

        if (!isPaused && !isDown && !scrubberDragging) {
            velX += autoScrollSpeed;
            container.scrollLeft += velX;
            velX *= 0.98;
            if (velX > 1.5) velX = 1.5;
        } else if (!isDown && isPaused && !scrubberDragging) {
            container.scrollLeft += velX;
            velX *= 0.95;
            if (Math.abs(velX) < 0.1) {
                isPaused = false;
                velX = 0;
            }
        }

        // Infinite Scroll Logic (Wrap around)
        const maxScroll = track.scrollWidth - container.clientWidth;
        if (container.scrollLeft >= maxScroll - 100) {
            container.scrollLeft = container.scrollLeft - (track.scrollWidth / 3);
        } else if (container.scrollLeft <= 100) {
            container.scrollLeft = container.scrollLeft + (track.scrollWidth / 3);
        }

        updateCardScales();
        if (isDesktop() && !scrubberDragging) scrollToScrubber();
        updateCounter();

        animationId = requestAnimationFrame(animate);
    }

    // Start Animation
    if (track && container) {
        requestAnimationFrame(() => {
            const trackWidth = track.scrollWidth;
            container.scrollLeft = trackWidth / 3;
            updateCardScales();
            if (scrubber) {
                scrubber.max = '1000';
                scrubber.value = '0';
                updateScrubberFill();
            }
        });
        lastTime = Date.now();
        animationId = requestAnimationFrame(animate);
    }

    if (container) {
        container.addEventListener("dragstart", (e) => e.preventDefault());

        // ── Touch Events (mobile / tablet only) ──────────────────────────
        container.addEventListener(
            "touchstart",
            (e) => {
                isDown = true;
                isPaused = true;
                startX = e.touches[0].pageX;
                scrollLeft = container.scrollLeft;
                velX = 0;
                showBadges();
            },
            { passive: false },
        );

        container.addEventListener("touchend", () => {
            isDown = false;
            hideBadgesDelayed(1200);
        });

        container.addEventListener(
            "touchmove",
            (e) => {
                if (!isDown) return;
                e.preventDefault();
                const x = e.touches[0].pageX;
                const walk = (x - startX) * 1.5;
                const newScrollLeft = scrollLeft - walk;
                velX = container.scrollLeft - newScrollLeft;
                container.scrollLeft = newScrollLeft;
            },
            { passive: false },
        );
    }

    // ── Desktop Scrubber ─────────────────────────────────────────────────
    if (scrubber) {
        scrubber.addEventListener('mousedown', () => {
            scrubberDragging = true;
            isPaused = true;
            showBadges();
        });

        scrubber.addEventListener('input', () => {
            updateScrubberFill();
            scrubberToScroll(parseFloat(scrubber.value));
        });

        scrubber.addEventListener('mouseup', () => {
            scrubberDragging = false;
            // Brief pause for momentum feel then resume
            setTimeout(() => { isPaused = false; velX = 0; }, 1200);
            hideBadgesDelayed(1200);
        });

        scrubber.addEventListener('touchstart', () => { scrubberDragging = true; isPaused = true; showBadges(); }, { passive: true });
        scrubber.addEventListener('touchend', () => {
            scrubberDragging = false;
            setTimeout(() => { isPaused = false; velX = 0; }, 1200);
            hideBadgesDelayed(1200);
        });
    }

    // ── Prev / Next Arrow Buttons ─────────────────────────────────────────
    function stepCarousel(direction: 1 | -1) {
        if (!container || !cards.length) return;
        isPaused = true;
        showBadges();
        // Scroll exactly one card width
        const cardEl = cards[0] as HTMLElement;
        const cardWidth = cardEl.clientWidth + 16; // 16 = gap-4
        container.scrollLeft += direction * cardWidth;
        hideBadgesDelayed(900);
        setTimeout(() => { isPaused = false; velX = 0; }, 600);
    }

    const prevBtn = document.getElementById('scrubber-prev');
    const nextBtn = document.getElementById('scrubber-next');
    prevBtn?.addEventListener('click', () => stepCarousel(-1));
    nextBtn?.addEventListener('click', () => stepCarousel(1));


</script>
