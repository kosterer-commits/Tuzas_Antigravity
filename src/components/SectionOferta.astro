---
const careers = [
  {
    title: "Ingeniería en Sistemas",
    img: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=800&auto=format&fit=crop",
    category: "Tecnología",
  },
  {
    title: "Ingeniería Industrial",
    img: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=800&auto=format&fit=crop",
    category: "Procesos",
  },
  {
    title: "Ingeniería Civil",
    img: "https://images.unsplash.com/photo-1503387762-592deb58ef4e?q=80&w=800&auto=format&fit=crop",
    category: "Construcción",
  },
  {
    title: "Arquitectura",
    img: "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800&auto=format&fit=crop",
    category: "Diseño",
  },
  {
    title: "Licenciatura en Administración",
    img: "https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=800&auto=format&fit=crop",
    category: "Negocios",
  },
  {
    title: "Ingeniería Química",
    img: "https://images.unsplash.com/photo-1532094349884-543bc11b234d?q=80&w=800&auto=format&fit=crop",
    category: "Ciencia",
  },
];
---

<section id="oferta" class="py-24 md:py-32 relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-emerald-600/10 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[30rem] h-[30rem] bg-indigo-600/10 rounded-full blur-[120px] mix-blend-screen pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">
    <div class="mb-16 md:mb-24 text-center reveal-on-scroll flex flex-col items-center">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 border border-white/10 backdrop-blur-sm mb-6 shadow-sm">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <h2 class="text-emerald-400 font-bold tracking-[0.2em] uppercase text-xs md:text-sm">
          Oferta Educativa
        </h2>
      </div>
      <h3 class="text-4xl md:text-5xl lg:text-7xl font-black text-white tracking-tight leading-tight max-w-4xl">
        Descubre tu <br class="hidden md:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 via-teal-300 to-emerald-600">
          Verdadera Vocación
        </span>
      </h3>
      <p class="mt-6 text-gray-400 max-w-2xl mx-auto text-lg md:text-xl font-medium">
        Explora nuestros programas académicos diseñados para formar a los líderes y profesionales del mañana con excelencia y visión global.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {
        careers.map((career, index) => (
          <a
            href=`${import.meta.env.BASE_URL}oferta`
            class={`group relative h-[420px] overflow-hidden rounded-2xl reveal-on-scroll reveal-delay-${(index % 3) * 100} border border-white/5 shadow-2xl bg-neutral-900`}
          >
            <!-- Background Image -->
            <img
              src={career.img}
              alt={career.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 opacity-60 group-hover:opacity-40"
            />
            
            <!-- Gradient Overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-neutral-950 via-neutral-950/60 to-transparent"></div>

            <!-- Content -->
            <div class="absolute inset-0 p-8 flex flex-col justify-end">
              <!-- Top Category Badge -->
              <div class="absolute top-6 left-6">
                <span class="px-3 py-1 text-xs font-semibold tracking-wider text-emerald-300 bg-emerald-900/40 border border-emerald-500/20 backdrop-blur-md rounded-full uppercase">
                  {career.category}
                </span>
              </div>

              <!-- Main Info -->
              <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500 ease-out z-10">
                <h4 class="text-2xl md:text-3xl font-bold text-white mb-3 mt-4 leading-tight group-hover:text-emerald-400 transition-colors drop-shadow-md">
                  {career.title}
                </h4>
                
                <!-- Hover Reveal Details -->
                <div class="flex items-center text-sm font-semibold text-white/80 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 mt-4">
                  <span class="flex items-center gap-2 text-emerald-300">
                    <span class="w-8 h-[2px] bg-emerald-500"></span>
                    Descubrir programa
                    <svg class="w-4 h-4 transform -translate-x-2 group-hover:translate-x-0 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </span>
                </div>
              </div>
            </div>
            
            <!-- Border Highlight Effect -->
            <div class="absolute inset-0 border border-emerald-500/0 group-hover:border-emerald-500/50 rounded-2xl transition-colors duration-500 pointer-events-none"></div>
          </a>
        ))
      }
    </div>

    <!-- Main CTA Button -->
    <div class="mt-20 md:mt-28 text-center reveal-on-scroll">
      <a
        href=`${import.meta.env.BASE_URL}oferta`
        class="group inline-flex items-center justify-center gap-3 px-8 py-4 bg-white text-neutral-950 font-bold tracking-[0.1em] uppercase rounded-full hover:bg-emerald-400 hover:text-white hover:shadow-[0_0_40px_rgba(52,211,153,0.4)] transition-all duration-300"
      >
        <span>Ver Toda la Oferta Educativa</span>
        <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
