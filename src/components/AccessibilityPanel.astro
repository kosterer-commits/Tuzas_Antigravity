---
// AccessibilityPanel.astro
// Solo exporta el BOTÓN disparador. El panel real vive en A11yPanel.astro (Layout).
---

<button
    id="a11y-toggle-btn"
    aria-label="Opciones de accesibilidad"
    aria-expanded="false"
    title="Accesibilidad"
    class="a11y-btn flex items-center justify-center w-10 h-10 rounded-full border border-current hover:bg-[#1B396A] hover:border-[#1B396A] hover:text-white transition-all duration-300 focus:outline-none focus:ring-4 focus:ring-[#1B396A]/30 shrink-0 shadow-sm"
>
    <!-- Accessibility Icon from Google Material Symbols -->
    <svg
        xmlns="http://www.w3.org/2000/svg"
        class="w-6 h-6"
        viewBox="0 0 24 24"
        fill="currentColor"
    >
        <path
            d="M12 2c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm9 7h-6v13h-2v-6h-2v6H9V9H3V7h18v2z"
        ></path>
    </svg>
</button>
