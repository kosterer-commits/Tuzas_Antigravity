---
const BASE = import.meta.env.BASE_URL;

const noticias = [
    {
        id: 1,
        categoria: "Institucional",
        titulo: "Entrega de Reconocimiento de Acreditación del Programa Ingeniería en Gestión Empresarial",
        extracto:
            "El día de hoy 5 de febrero en el Instituto Tecnológico de Pachuca se llevó a cabo el acto protocolario de entrega del Reconocimiento de Acreditación del programa educativo de la Licenciatura en Gestión Empresarial.",
        fecha: "05 Feb 2026",
        imagen: `${BASE}images/Noticias/nota99.jpg`,
        pdf: `${BASE}archives/Noticias/ENTREGA DE RECONOCIMIENTO DE ACREDITACION DEL PROGRAMA DE INGENIERIA EN GESTION EMPRESARIAL (1).pdf`,
        destacado: true,
    },
    {
        id: 2,
        categoria: "Nombramientos",
        titulo: "Nombramiento a Titular del Departamento de Ciencias Económico Administrativas",
        extracto:
            "En la sala de juntas del Instituto Tecnológico de Pachuca, se llevó a cabo la entrega del nombramiento del titular del Departamento de Ciencias Económico-Administrativas.",
        fecha: "20 Ene 2026",
        imagen: `${BASE}images/Noticias/nota98.png`,
        pdf: `${BASE}archives/Noticias/Nombramiento Eco-Adm 2026 (1).pdf`,
        destacado: false,
    },
    {
        id: 3,
        categoria: "Nombramientos",
        titulo: "Nombramiento a Titular de la Subdirección de Planeación y Vinculación",
        extracto:
            "En la sala de juntas del Instituto Tecnológico de Pachuca, se llevó a cabo la entrega del nombramiento del titular de la Subdirección de Planeación y Vinculación.",
        fecha: "08 Dic 2025",
        imagen: `${BASE}images/Noticias/nota96.jpg`,
        pdf: `${BASE}archives/Noticias/Nombramiento SPV 2025 (1).pdf`,
        destacado: false,
    },
    {
        id: 4,
        categoria: "Nombramientos",
        titulo: "Nombramiento a Titular del Departamento de Ingeniería Eléctrica y Electrónica",
        extracto:
            "En la sala de juntas del Instituto Tecnológico de Pachuca, se llevó a cabo la entrega del nombramiento del titular del Departamento de Ingeniería Eléctrica y Electrónica.",
        fecha: "08 Dic 2025",
        imagen: `${BASE}images/Noticias/nota97.jpg`,
        pdf: `${BASE}archives/Noticias/Nombramiento DIEE 2025 (1).pdf`,
        destacado: false,
    },
];

const categoriaColors: { [key: string]: string } = {
    Institucional: "bg-blue-600",
    Nombramientos: "bg-indigo-600",
    Investigación: "bg-purple-600",
    Eventos: "bg-emerald-600",
    Académico: "bg-green-600",
    Deportes: "bg-orange-600",
    Vinculación: "bg-cyan-600",
};
---

<section class="py-10 md:py-16">
    <div
        class="max-w-[1400px] 2xl:max-w-[1600px] w-full mx-auto px-4 sm:px-6 lg:px-8"
    >
        <!-- Header -->
        <div class="text-center mb-10 reveal-on-scroll">
            <div class="flex items-center justify-center gap-3 mb-4">
                <div class="w-12 h-1 bg-blue-500 rounded-full"></div>
                <span
                    class="text-blue-400 font-bold tracking-[0.2em] uppercase text-sm"
                    >Comunicación Institucional</span
                >
                <div class="w-12 h-1 bg-blue-500 rounded-full"></div>
            </div>
            <h3
                class="text-3xl sm:text-4xl md:text-5xl font-black text-white uppercase tracking-tight mb-4"
            >
                Últimas <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500"
                    >Noticias</span
                >
            </h3>
            <p
                class="text-base text-gray-300 max-w-2xl mx-auto font-light leading-relaxed"
            >
                Mantente informado con las últimas noticias y comunicados
                relevantes del Instituto Tecnológico de Pachuca.
            </p>
        </div>

        <!-- News Grid: 4 cards in a single horizontal row -->
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 xl:gap-8"
        >
            {
                noticias.map((noticia) => (
                    <article class="group relative overflow-hidden rounded-2xl bg-white shadow-lg hover:shadow-2xl transition-all duration-500 reveal-on-scroll flex flex-col">
                        {/* Image Container */}
                        <div class="relative overflow-hidden aspect-[4/3]">
                            <img
                                src={noticia.imagen}
                                alt={noticia.titulo}
                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            />
                            {/* Overlay Gradient */}
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-60 group-hover:opacity-80 transition-opacity duration-300" />

                            {/* Category Badge */}
                            <div class="absolute top-4 left-4">
                                <span
                                    class={`inline-block px-3 py-1 rounded-full text-xs font-bold text-white ${categoriaColors[noticia.categoria] ?? "bg-gray-700"} backdrop-blur-sm`}
                                >
                                    {noticia.categoria}
                                </span>
                            </div>

                            {/* Date */}
                            <div class="absolute top-4 right-4">
                                <div class="bg-white/95 backdrop-blur-sm px-3 py-1 rounded-full">
                                    <span class="text-xs font-bold text-gray-900">
                                        📅 {noticia.fecha}
                                    </span>
                                </div>
                            </div>
                        </div>

                        {/* Content */}
                        <div class="p-6 xl:p-8 flex flex-col flex-1">
                            <h4 class="text-lg xl:text-xl font-bold text-gray-900 mb-3 group-hover:text-blue-600 transition-colors duration-300 line-clamp-3">
                                {noticia.titulo}
                            </h4>
                            <p class="text-gray-600 leading-relaxed mb-6 text-base line-clamp-3 flex-1">
                                {noticia.extracto}
                            </p>

                            {/* Read More Link */}
                            <a
                                href={noticia.pdf}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 text-base xl:text-lg font-bold text-blue-600 hover:text-blue-700 transition-colors group/link mt-auto"
                            >
                                Ver comunicado
                                <svg
                                    class="w-4 h-4 transform group-hover/link:translate-x-1 transition-transform"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"
                                    />
                                </svg>
                            </a>
                        </div>

                        {/* Hover Effect Border */}
                        <div class="absolute inset-0 border-2 border-transparent group-hover:border-blue-600 rounded-2xl transition-all duration-300 pointer-events-none" />
                    </article>
                ))
            }
        </div>
    </div>
</section>

<style>
    /* Additional hover effects for news cards */
    article {
        transform: translateY(0);
    }

    article:hover {
        transform: translateY(-8px);
    }
</style>
