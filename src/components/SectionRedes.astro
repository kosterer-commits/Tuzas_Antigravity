---
// Enhanced social media section with modern design
const BASE = import.meta.env.BASE_URL;
const socialLinks = [
    {
        name: "Facebook",
        url: "https://www.facebook.com/p/TecNM-Pachuca-61557528505129/?locale=es_LA",
        color: "bg-blue-600",
        hoverColor: "hover:bg-blue-700",
        followers: "12.5K",
    },
    {
        name: "Instagram", 
        url: "https://www.instagram.com/tecnm.pachuca/",
        color: "bg-gradient-to-br from-purple-600 via-pink-600 to-orange-500",
        hoverColor: "hover:opacity-90",
        followers: "8.2K",
    },
    {
        name: "X",
        url: "https://x.com/tecnmpachuca?lang=es",
        color: "bg-black",
        hoverColor: "hover:bg-gray-800",
        followers: "5.8K",
    },
    {
        name: "YouTube",
        url: "https://www.youtube.com/@TecNMCampusPachuca",
        color: "bg-red-600",
        hoverColor: "hover:bg-red-700",
        followers: "3.4K",
    },
];
---

<section class="py-32 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <!-- LEFT: Header & Social Links -->
            <div class="reveal-on-scroll relative">

                <!-- Tuza decorativa (detrás del texto, lado izquierdo) -->
                <div class="absolute inset-y-0 -left-64 pointer-events-none z-0 flex items-center">
                    <img
                        src={`${BASE}icons/tuza_sociales.png`}
                        alt=""
                        aria-hidden="true"
                        class="h-full w-auto object-contain"
                    />
                </div>

                <!-- Contenido (encima de la tuza) -->
                <div class="relative z-10">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="w-12 h-1 bg-pink-500 rounded-full"></div>
                        <h2 class="text-pink-400 font-bold tracking-[0.2em] uppercase text-sm">
                            Comunidad
                        </h2>
                    </div>
                    <h3 class="text-4xl md:text-5xl font-black text-white uppercase tracking-tight leading-tight mb-6">
                        Conecta con<br />
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">Nosotros</span>
                    </h3>
                    <p class="text-lg text-gray-200 mb-12 max-w-md">
                        Sigue de cerca la vida estudiantil, eventos y noticias
                        oficiales en nuestras redes sociales.
                    </p>
                </div>

                <!-- Social Media Links Grid -->
                <div class="grid grid-cols-2 gap-4 relative z-10">
                    {
                        socialLinks.map((social, index) => (
                            <a
                                href={social.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class={`group relative overflow-hidden rounded-2xl ${social.color} ${social.hoverColor} p-6 text-white transition-all duration-300 hover:scale-105 hover:shadow-2xl reveal-delay-${index * 100}`}
                            >
                                <!-- Icon -->
                                <div class="mb-4">
                                    {social.name === "Facebook" && (
                                        <svg
                                            class="w-8 h-8"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                                        </svg>
                                    )}
                                    {social.name === "Instagram" && (
                                        <svg
                                            class="w-8 h-8"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678c-3.405 0-6.162 2.76-6.162 6.162 0 3.405 2.76 6.162 6.162 6.162 3.405 0 6.162-2.76 6.162-6.162 0-3.405-2.76-6.162-6.162-6.162zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405c0 .795-.646 1.44-1.44 1.44-.795 0-1.44-.646-1.44-1.44 0-.794.646-1.439 1.44-1.439.793-.001 1.44.645 1.44 1.439z" />
                                        </svg>
                                    )}
                                    {social.name === "X" && (
                                        <svg
                                            class="w-8 h-8"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                                        </svg>
                                    )}
                                    {social.name === "YouTube" && (
                                        <svg
                                            class="w-8 h-8"
                                            fill="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                                        </svg>
                                    )}
                                </div>

                                <!-- Content -->
                                <div>
                                    <p class="font-bold text-lg mb-1">
                                        {social.name}
                                    </p>
                                    <p class="text-sm opacity-90">
                                        {social.followers} seguidores
                                    </p>
                                </div>

                                <!-- Hover Arrow -->
                                <div class="absolute bottom-6 right-6 opacity-0 group-hover:opacity-100 transform translate-x-2 group-hover:translate-x-0 transition-all duration-300">
                                    <svg
                                        class="w-5 h-5"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"
                                        />
                                    </svg>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- RIGHT: Interactive Social Feed Preview (Facebook Page Plugin) -->
            <div class="relative h-[600px] reveal-on-scroll reveal-delay-200 flex justify-center lg:justify-end items-center" id="social-feed">
                
                <!-- Glow Effect Background -->
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-blue-600/20 rounded-full blur-[100px] -z-10 pointer-events-none"></div>

                <!-- Glassmorphism Container for Widget -->
                <div class="w-full max-w-[400px] h-[600px] bg-white/10 backdrop-blur-xl border border-white/20 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.3)] overflow-hidden relative group flex flex-col">
                    
                    <!-- Tabs Header -->
                    <div class="p-3 shrink-0 flex items-center justify-between border-b border-white/10 bg-black/20">
                        <div class="flex gap-1.5 overflow-x-auto pb-1 w-full snap-x" style="scrollbar-width: none;">
                            <button class="social-tab active snap-start shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition-all duration-300 text-white bg-blue-600 shadow-md transform scale-100" data-target="feed-fb" data-color="bg-blue-600">
                                Facebook
                            </button>
                            <button class="social-tab snap-start shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition-all duration-300 text-gray-300 hover:bg-white/10 hover:text-white transform scale-95 opacity-70 hover:opacity-100" data-target="feed-x" data-color="bg-black">
                                X (Twitter)
                            </button>
                            <button class="social-tab snap-start shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition-all duration-300 text-gray-300 hover:bg-white/10 hover:text-white transform scale-95 opacity-70 hover:opacity-100" data-target="feed-ig" data-color="bg-gradient-to-r from-purple-500 to-pink-500">
                                Instagram
                            </button>
                            <button class="social-tab snap-start shrink-0 px-4 py-2 rounded-xl text-xs font-bold transition-all duration-300 text-gray-300 hover:bg-white/10 hover:text-white transform scale-95 opacity-70 hover:opacity-100" data-target="feed-yt" data-color="bg-red-600">
                                YouTube
                            </button>
                        </div>
                    </div>

                    <!-- Feed Content Area -->
                    <div class="relative flex-1 w-full bg-white overflow-hidden">
                        
                        <!-- Facebook Feed -->
                        <div id="feed-fb" class="feed-panel absolute inset-0 transition-opacity duration-300 opacity-100 z-10 flex flex-col">
                            <div class="w-full h-full bg-white">
                                <iframe 
                                    src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fp%2FTecNM-Pachuca-61557528505129&tabs=timeline&width=400&height=550&small_header=false&adapt_container_width=true&hide_cover=false&show_facepile=false&appId" 
                                    width="400" 
                                    height="100%" 
                                    style="border:none;overflow:hidden; width: 100%;" 
                                    scrolling="yes" 
                                    frameborder="0" 
                                    allowfullscreen="true" 
                                    allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
                                    class="w-full h-full"
                                ></iframe>
                            </div>
                        </div>

                        <!-- X (Twitter) Feed -->
                        <div id="feed-x" class="feed-panel absolute inset-0 transition-opacity duration-300 opacity-0 z-0 pointer-events-none bg-white overflow-y-auto overflow-x-hidden flex items-center justify-center">
                            <div class="w-full h-[550px] bg-white">
                                <a class="twitter-timeline" data-height="550" data-width="400" data-theme="light" data-chrome="noheader nofooter noborders transparent" href="https://twitter.com/tecnmpachuca?ref_src=twsrc%5Etfw">Tweets de @tecnmpachuca</a>
                                <script async src="https://platform.twitter.com/widgets.js" charset="utf-8" is:inline></script>
                            </div>
                        </div>

                        <!-- Instagram Feed (Iframe Embed) -->
                        <div id="feed-ig" class="feed-panel absolute inset-0 transition-opacity duration-300 opacity-0 z-0 pointer-events-none bg-white flex flex-col items-center justify-center relative overflow-hidden">
                            <iframe 
                                src="https://www.instagram.com/tecnm.pachuca/embed" 
                                width="100%" 
                                height="100%" 
                                frameborder="0" 
                                scrolling="yes" 
                                allowtransparency="true"
                                class="w-full h-[550px] border-none"
                            ></iframe>
                        </div>

                        <!-- YouTube Feed (Interactive Card) -->
                        <div id="feed-yt" class="feed-panel absolute inset-0 transition-opacity duration-300 opacity-0 z-0 pointer-events-none bg-zinc-900 flex flex-col items-center justify-center p-8 text-center relative overflow-hidden">
                            <!-- Background Decor -->
                            <div class="absolute inset-x-0 top-0 h-32 bg-gradient-to-b from-red-600/20 to-transparent pointer-events-none"></div>

                            <div class="w-20 h-20 bg-red-600 rounded-3xl p-1 shadow-xl shadow-red-600/30 mb-6 transform rotate-6 hover:rotate-0 transition-transform duration-500 relative z-10 hover:scale-110 cursor-pointer">
                                <a href="https://www.youtube.com/@TecNMCampusPachuca" target="_blank" class="w-full h-full bg-white rounded-[20px] flex items-center justify-center">
                                    <svg class="w-10 h-10 text-red-600 ml-1" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                                    </svg>
                                </a>
                            </div>
                            <h4 class="text-2xl font-black text-white mb-2 decoration-red-500 relative z-10">Actividad en YouTube</h4>
                            <p class="text-sm text-gray-400 mb-8 max-w-[250px] relative z-10">Conoce más sobre nuestros eventos, proyectos e instalaciones en formato de video.</p>
                            <a href="https://www.youtube.com/@TecNMCampusPachuca" target="_blank" class="relative z-10 px-8 py-3 bg-red-600 text-white font-bold rounded-full shadow-lg hover:shadow-red-600/50 hover:scale-105 transition-all duration-300 flex items-center gap-2">
                                <svg class="w-5 h-5 animate-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                Ir al Canal
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll('.social-tab');
        const panels = document.querySelectorAll('.feed-panel');

        tabs.forEach(tab => {
            tab.addEventListener('click', () => {
                const targetId = tab.getAttribute('data-target');
                const brandColorClass = tab.getAttribute('data-color') || '';
                const gradientClasses = brandColorClass.includes('gradient') ? brandColorClass.split(' ') : null;

                // Reset all tabs
                tabs.forEach(t => {
                    t.classList.remove('active', 'text-white', 'shadow-md', 'scale-100', 'bg-blue-600', 'bg-black', 'bg-red-600', 'bg-gradient-to-r', 'from-purple-500', 'to-pink-500');
                    t.classList.add('text-gray-300', 'scale-95', 'opacity-70');
                });

                // Activate clicked tab
                tab.classList.remove('text-gray-300', 'scale-95', 'opacity-70');
                tab.classList.add('active', 'text-white', 'shadow-md', 'scale-100');
                
                if (gradientClasses) {
                    tab.classList.add(...gradientClasses);
                } else if (brandColorClass) {
                    tab.classList.add(brandColorClass);
                }

                // Show target panel
                panels.forEach(panel => {
                    if(panel.id === targetId) {
                        panel.classList.remove('opacity-0', 'z-0', 'pointer-events-none');
                        panel.classList.add('opacity-100', 'z-10', 'pointer-events-auto');

                        // Forzar renderizado de X / Twitter al mostrar la pestaña
                        if (targetId === 'feed-x' && typeof window !== 'undefined' && (window as any).twttr) {
                            (window as any).twttr.widgets.load(panel);
                        }
                    } else {
                        panel.classList.remove('opacity-100', 'z-10', 'pointer-events-auto');
                        panel.classList.add('opacity-0', 'z-0', 'pointer-events-none');
                    }
                });
            });
        });
    });
</script>


