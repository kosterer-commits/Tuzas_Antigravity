---

<header
    id="main-header"
    class="fixed top-0 z-50 w-full transition-all duration-500 bg-transparent text-white"
>
    <div class="max-w-[1920px] mx-auto px-3 sm:px-6 lg:px-12">
        <div
            class="flex flex-col justify-center py-2 lg:py-0 min-h-[4rem] sm:min-h-[6rem] lg:min-h-[7rem]"
        >
            <!-- â”€â”€ ROW 1: Logo + Primary Nav + Controls â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <div class="flex justify-between items-center w-full">
                <!-- Logo (Left) -->
                <div class="flex-shrink-0 z-50">
                    <a
                        href={BASE}
                        class="group flex items-center gap-2 sm:gap-4 bg-white border border-gray-200 rounded-full px-3 sm:px-6 py-1.5 shadow-[0_4px_16px_rgba(0,0,0,0.08)] hover:bg-white hover:shadow-[0_8px_24px_rgba(0,0,0,0.15)] transition-all duration-300"
                    >
                        <img
                            src={`${BASE}icons/SEP.png`}
                            alt="SEP"
                            class="h-7 sm:h-10 md:h-11 w-auto object-contain group-hover:opacity-80 transition-all duration-300 logo-icon"
                        />
                        <span class="h-8 w-px bg-gray-300 hidden sm:block"
                        ></span>
                        <img
                            src={`${BASE}icons/TECNM.png`}
                            alt="TecNM"
                            class="h-6 sm:h-8 md:h-9 w-auto object-contain group-hover:opacity-80 transition-all duration-300 logo-icon"
                        />
                        <span class="h-8 w-px bg-gray-300 hidden sm:block"
                        ></span>
                        <img
                            src={`${BASE}icons/TecPachuca.png`}
                            alt="TecPachuca"
                            class="h-7 sm:h-10 md:h-11 w-auto object-contain group-hover:opacity-80 transition-all duration-300 logo-icon"
                        />
                    </a>
                </div>

                <!-- Primary Nav: INICIO â†’ DEPARTAMENTOS -->
                <nav class="hidden lg:flex items-center gap-4 xl:gap-6">
                    {
                        links.map((link) => (
                            <a
                                href={link.href}
                                class="relative text-xs font-bold tracking-[0.15em] uppercase hover:opacity-90 transition-all after:content-[''] after:absolute after:-bottom-1.5 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                            >
                                {link.name}
                            </a>
                        ))
                    }

                    <!-- Departments Dropdown -->
                    <div class="relative group" id="dept-dropdown">
                        <button
                            class="relative text-xs font-bold tracking-[0.15em] uppercase flex items-center gap-1 hover:opacity-90 transition-all after:content-[''] after:absolute after:-bottom-1.5 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                        >
                            DEPARTAMENTOS
                            <svg
                                class="w-3 h-3 transition-transform group-hover:rotate-180"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path>
                            </svg>
                        </button>
                        <div
                            class="absolute top-full right-0 mt-3 w-64 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden"
                        >
                            {
                                departamentos.map((dept, index) => (
                                    <a
                                        href={dept.href}
                                        class="block px-6 py-3.5 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0 relative before:content-[''] before:absolute before:left-0 before:top-0 before:h-full before:w-1 before:bg-[#1B396A] before:opacity-0 hover:before:opacity-100 before:transition-opacity"
                                        style={`animation-delay: ${index * 50}ms`}
                                    >
                                        {dept.name}
                                    </a>
                                ))
                            }
                        </div>
                    </div>
                </nav>

                <!-- Mobile Menu Toggle (Right) -->
                <div class="lg:hidden z-50 flex-shrink-0">
                    <button
                        id="menu-toggle"
                        class="p-2 -mr-2 text-current hover:opacity-70 transition-opacity focus:outline-none"
                        aria-label="Menu"
                    >
                        <div
                            class="w-6 h-4 relative flex flex-col justify-between"
                        >
                            <span
                                id="line-1"
                                class="w-full h-0.5 bg-current transform transition-all duration-300 origin-center"
                            ></span>
                            <span
                                id="line-2"
                                class="w-full h-0.5 bg-current transform transition-all duration-300 opacity-100"
                            ></span>
                            <span
                                id="line-3"
                                class="w-full h-0.5 bg-current transform transition-all duration-300 origin-center"
                            ></span>
                        </div>
                    </button>
                </div>

                <div class="hidden lg:flex items-center gap-3">
                    <!-- Accessibility Button (desktop) -->
                    <AccessibilityPanel />
                </div>
            </div>

            <!-- â”€â”€ ROW 2: Secondary Nav (desktop only) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <nav
                class="hidden lg:flex items-center gap-4 xl:gap-5 justify-end pt-1 pb-1"
            >
                <!-- Coronavirus (simple link) -->
                <a
                    href={`${BASE}aviso_importante`}
                    class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >CORONAVIRUS</a
                >

                <!-- Avisos Importantes Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        AVISOS
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden z-50"
                    >
                        {
                            avisosImportantes.map((item) => (
                                <a
                                    href={item.href}
                                    target="_blank"
                                    class="block px-6 py-3.5 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Sitios de InterÃ©s Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        SITIOS
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden z-50"
                    >
                        {
                            sitiosInteres.map((item) => (
                                <a
                                    href={item.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="block px-6 py-3.5 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Convocatorias -->
                <a
                    href={`${BASE}convocatorias`}
                    class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >CONVOCATORIAS</a
                >

                <!-- Publicaciones Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        PUBLICACIONES
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden max-h-[70vh] overflow-y-auto z-50"
                    >
                        {
                            publicaciones.map((item) => (
                                <a
                                    href={item.href}
                                    target="_blank"
                                    class="block px-6 py-3 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Agenda y Servicios Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        AGENDA
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-72 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden z-50"
                    >
                        {
                            agendaServicios.map((item) => (
                                <a
                                    href={item.href}
                                    target="_blank"
                                    class="block px-6 py-3.5 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Sistemas de GestiÃ³n Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        SISTEMAS
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden z-50"
                    >
                        {
                            sistemasGestion.map((item) => (
                                <a
                                    href={item.href}
                                    class="block px-6 py-3.5 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <!-- Formatos y Reglamentos Dropdown -->
                <div class="relative group">
                    <button
                        class="relative text-[0.68rem] font-bold tracking-[0.12em] uppercase flex items-center gap-1 hover:opacity-90 transition-all whitespace-nowrap after:content-[''] after:absolute after:-bottom-1 after:left-1/2 after:w-0 after:h-[2px] after:bg-current after:transition-all after:duration-300 hover:after:w-full hover:after:left-0"
                    >
                        FORMATOS
                        <svg
                            class="w-2.5 h-2.5 transition-transform group-hover:rotate-180"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <div
                        class="absolute top-full right-0 mt-2 w-80 bg-white/95 backdrop-blur-md rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 overflow-hidden max-h-[70vh] overflow-y-auto z-50"
                    >
                        {
                            formatosReglamentos.map((item) => (
                                <a
                                    href={item.href}
                                    target="_blank"
                                    class="block px-6 py-3 text-sm font-semibold text-gray-700 hover:bg-[#1B396A]/5 hover:text-[#1B396A] hover:pl-8 transition-all duration-300 border-b border-gray-50 last:border-b-0"
                                >
                                    {item.name}
                                </a>
                            ))
                        }
                    </div>
                </div>
            </nav>
        </div>
    </div>
</header>

<!-- Quick Links Panel (global, left edge) -->
<EnlacesRapidos />

<!-- Mobile Overlay Menu (Outside Header) -->
<div
    id="mobile-menu"
    class="fixed inset-0 bg-black/60 z-[9999] pointer-events-none opacity-0 transition-opacity duration-300"
>
    <!-- Menu Panel -->
    <div
        id="mobile-menu-panel"
        class="absolute right-0 top-0 bottom-0 w-[88%] max-w-xs bg-white transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.77,0,0.175,1)] overflow-y-auto pointer-events-auto shadow-2xl flex flex-col"
    >
        <!-- Panel Header accent -->
        <div class="bg-[#1B396A] px-6 pt-14 pb-5 flex-shrink-0">
            <p
                class="text-white/60 text-[0.6rem] font-bold tracking-[0.2em] uppercase"
            >
                Instituto Tecnológico de Pachuca
            </p>
            <p class="text-white text-lg font-black tracking-tight mt-0.5">
                Navegación
            </p>
        </div>

        <!-- Links -->
