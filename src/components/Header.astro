const sistemasGestion = [
    { name: "Sistema de Gestión Integrado", href: `${BASE}sgi` },
    {
        name: "Sistema de Gestión de Igualdad de Género y no Discriminación",
        href: `${BASE}sgig`,
    },
];

const formatosReglamentos = [
    {
        name: "Solicitud de Servicio Social",
        href: `${BASE}SGC/proceso estrategico de vinculacion/ITPAC-VI-PO-002/ITPAC-VI-PO-002-01.doc`,
    },
    {
        name: "Carta Compromiso de Servicio Social",
        href: `${BASE}SGC/proceso estrategico de vinculacion/ITPAC-VI-PO-002/ITPAC-VI-PO-002-02.doc`,
    },
    {
        name: "Plan de Actividades de Servicio Social",
        href: `${BASE}SGC/proceso estrategico de vinculacion/ITPAC-VI-PO-002/ITPAC-VI-PO-002-09.docx`,
    },
    {
        name: "Reporte Bimestral de Servicio Social",
